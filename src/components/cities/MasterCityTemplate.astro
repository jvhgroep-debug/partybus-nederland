---
import type { CityPageData } from '../../data/cities/types';
import { getRelatedCities } from '../../data/cities/registry';
import { resolveCityHeroImage } from '../../lib/cityImages';
import CityHero from './CityHero.astro';
import CityIntro from './CityIntro.astro';
import CityDestinations from './CityDestinations.astro';
import CityActivities from './CityActivities.astro';
import CityOccasions from './CityOccasions.astro';
import CityTrustBar from './CityTrustBar.astro';
import CityWhy from './CityWhy.astro';
import CityHowItWorks from './CityHowItWorks.astro';
import CityPickupLocations from './CityPickupLocations.astro';
import CityConversionBand from './CityConversionBand.astro';
import CityFaq from './CityFaq.astro';
import CityRelatedCities from './CityRelatedCities.astro';
import CityCta from './CityCta.astro';
import InfoGuide from '../shared/InfoGuide.astro';
import {
	bookingTips,
	cityInfoLead,
	compareChecklist,
	pricingFactors,
} from '../../data/guides/partybusInfo';

interface Props {
	city: CityPageData;
}

const { city } = Astro.props;
const relatedCities = getRelatedCities(city.slug, city.relatedCitySlugs);
const heroImage = resolveCityHeroImage(city.slug);
const requestSteps = [
	{
		title: 'Deel jullie rit',
		text: `Vul datum, groepsgrootte, opstapplaats in ${city.name}, bestemming en gewenste tijden in.`,
	},
	{
		title: 'Vergelijk voorstellen',
		text: 'Bekijk prijs, buscapaciteit, faciliteiten en voorwaarden van passende aanbieders naast elkaar.',
	},
	{
		title: 'Kies zelf',
		text: 'Je aanvraag is vrijblijvend. Jij bepaalt welke aanbieder het beste past en maakt de boeking rechtstreeks rond.',
	},
] as const;
---

<div class="master-city">
	<CityHero
		title={city.h1}
		subtitle={city.hero.subtitle}
		image={heroImage.src}
		imageAlt={heroImage.alt}
		imageWidth={heroImage.width}
		imageHeight={heroImage.height}
		whatsappHref={city.hero.whatsappHref ?? city.cta.whatsappHref}
		primaryHref="/gratis-partybus-offertes-aanvragen/"
		trustItems={city.hero.trustItems}
	/>

	<CityTrustBar items={city.hero.trustItems ?? []} />

	<CityIntro
		title={city.intro.title}
		paragraphs={city.intro.paragraphs}
		image={city.intro.image}
		imageAlt={city.intro.imageAlt}
	/>

	<CityWhy title={`Waarom een partybus huren vanuit ${city.name}?`} lead={city.why.lead} items={city.why.items} />

	<CityOccasions title={city.occasions.title} lead={city.occasions.lead} items={city.occasions.items} />

	<CityConversionBand cityName={city.name} whatsappHref={city.cta.whatsappHref} />

	<CityHowItWorks steps={requestSteps} />

	<InfoGuide
		eyebrow="Informatie"
		title={`Partybus vanuit ${city.name}: prijzen & tips`}
		lead={cityInfoLead(city.name)}
		cards={pricingFactors}
		checklist={compareChecklist}
	/>

	<CityPickupLocations
		title={city.pickup.title}
		lead={city.pickup.lead}
		items={city.pickup.items}
		note={city.pickup.note}
	/>

	<CityDestinations
		title={city.locations.title}
		lead={city.locations.lead}
		items={city.locations.items}
		eyebrow="Bestemmingen"
	/>

	<CityActivities
		title={city.activities.title}
		lead={city.activities.lead}
		items={city.activities.items}
		eyebrow="Festivals"
	/>

	<InfoGuide
		eyebrow="Tips"
		title={`Praktische tips voor een rit vanuit ${city.name}`}
		lead={`Zo bereid je een partybusrit vanuit ${city.name} goed voor — van route tot voorwaarden.`}
		cards={bookingTips}
	/>

	<CityFaq items={city.faqs} cityName={city.name} />

	{relatedCities.length > 0 && <CityRelatedCities cityName={city.name} cities={relatedCities} />}

	<nav class="master-city__links section__inner" aria-label="Vervolgstappen">
		<a href="/gratis-partybus-offertes-aanvragen/">Gratis offertes aanvragen →</a>
		<a href="/hoe-werkt-het/">Hoe werkt vergelijken? →</a>
		<a href="/#diensten">Bekijk diensten →</a>
		<a href="/gids/partybus-huren/">Meer lezen in de partybus-gids →</a>
		<a href="/kennisbank/">Naar de kennisbank →</a>
	</nav>

	<CityCta
		title={city.cta.title}
		text={city.cta.text}
		whatsappHref={city.cta.whatsappHref}
		image={city.cta.image}
		primaryHref="/gratis-partybus-offertes-aanvragen/"
	/>
</div>
<style>
	.master-city :global(.section) {
		padding-block: clamp(4.75rem, 10vw, 8.25rem);
	}

	@media (max-width: 640px) {
		.master-city :global(.section) {
			padding-block: clamp(3.5rem, 14vw, 5rem);
		}
	}

	.master-city__links {
		display: grid;
		gap: 0.65rem;
		margin: 0 0 1.25rem;
		padding-bottom: 0;
	}

	.master-city__links a {
		color: var(--color-primary);
		font-weight: 700;
	}
</style>
