---
import type { CityPageData } from '../../data/cities/types';
import { getRelatedCities } from '../../data/cities/registry';
import { buildLocalCityImages } from '../../data/cities/localTypes';
import CityHero from './CityHero.astro';
import CityIntro from './CityIntro.astro';
import LocalCityGuide from './LocalCityGuide.astro';
import CityFaq from './CityFaq.astro';
import CityRelatedCities from './CityRelatedCities.astro';
import CityCta from './CityCta.astro';
import InfoGuide from '../shared/InfoGuide.astro';
import { cityInfoLead, compareChecklist, pricingFactors } from '../../data/guides/partybusInfo';

interface Props {
	city: CityPageData;
}

const { city } = Astro.props;
const profile = city.localProfile;
const images = buildLocalCityImages(profile);
const relatedCities = getRelatedCities(city.slug, profile.relatedCitySlugs);
---

<div class="master-city">
	<CityHero
		title={city.h1}
		subtitle={city.hero.subtitle}
		image={images.hero.src}
		imageAlt={images.hero.alt}
		imageWidth={images.hero.width}
		imageHeight={images.hero.height}
		whatsappHref={city.hero.whatsappHref ?? city.cta.whatsappHref}
		primaryHref="/gratis-partybus-offertes-aanvragen/"
		trustItems={city.hero.trustItems}
	/>

	<CityIntro
		title={profile.intro.title}
		paragraphs={profile.intro.paragraphs}
		image={images.nightlife.src}
		imageAlt={profile.intro.imageAlt}
		imageWidth={images.nightlife.width}
		imageHeight={images.nightlife.height}
	/>

	<LocalCityGuide profile={profile} images={images} />

	<InfoGuide
		eyebrow="Informatie"
		title={`Partybus vanuit ${city.name}: prijzen & tips`}
		lead={cityInfoLead(city.name)}
		cards={pricingFactors}
		checklist={compareChecklist}
	/>

	<CityFaq items={profile.faqs} cityName={city.name} />

	{relatedCities.length > 0 && <CityRelatedCities cityName={city.name} cities={relatedCities} />}

	<p class="master-city__guide-link section__inner">
		<a href="/gids/partybus-huren/">Meer lezen in de complete partybus-gids →</a>
	</p>

	<CityCta
		title={city.cta.title}
		text={city.cta.text}
		whatsappHref={city.cta.whatsappHref}
		image={images.destination.src}
		primaryHref="/gratis-partybus-offertes-aanvragen/"
	/>
</div>
<style>
	.master-city :global(.section) {
		padding-block: clamp(4.75rem, 10vw, 8.25rem);
	}

	@media (max-width: 640px) {
		.master-city :global(.section) {
			padding-block: clamp(3.5rem, 14vw, 5rem);
		}
	}

	.master-city__guide-link {
		margin: 0 0 1rem;
		padding-bottom: 0;
	}

	.master-city__guide-link a {
		color: var(--color-primary);
		font-weight: 700;
	}
</style>
