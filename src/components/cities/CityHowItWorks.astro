---
interface Step {
	title: string;
	text: string;
}

interface Props {
	steps: readonly Step[];
}

const { steps } = Astro.props;
---

<section class="section" aria-labelledby="city-how-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Aanvraag</p>
			<h2 id="city-how-title" class="section__title">Hoe werkt een aanvraag?</h2>
		</div>
		<ol class="city-how__grid">
			{
				steps.map((step, index) => (
					<li class="city-how__card reveal">
						<span class="city-how__num">{index + 1}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.city-how__grid {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 1.1rem;
	}

	@media (min-width: 900px) {
		.city-how__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.city-how__card {
		position: relative;
		padding: 1.5rem 1.3rem 1.55rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 6%, #090909);
		height: 100%;
	}

	.city-how__num {
		display: inline-grid;
		place-items: center;
		width: 2.2rem;
		height: 2.2rem;
		margin-bottom: 0.85rem;
		border-radius: 999px;
		background: var(--color-primary);
		color: #111;
		font-family: var(--font-display);
		font-weight: 800;
	}

	.city-how__card h3 {
		margin: 0 0 0.5rem;
		font-family: var(--font-display);
		font-size: 1.15rem;
	}

	.city-how__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}
</style>