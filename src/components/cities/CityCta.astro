---
import Button from '../buttons/Button.astro';

interface Props {
	title: string;
	text: string;
	whatsappHref: string;
	image: string;
	primaryHref?: string;
}

const { title, text, whatsappHref, image, primaryHref = '/#offerte' } = Astro.props;
---

<section id="offerte-stad" class="section city-cta" aria-labelledby="city-cta-title">
	<div class="city-cta__panel section__inner reveal">
		<div class="city-cta__media" aria-hidden="true">
			<img src={image} alt="" width="1672" height="941" loading="lazy" decoding="async" />
			<div class="city-cta__veil"></div>
		</div>
		<div class="city-cta__content">
			<p class="section__eyebrow">Call-to-action</p>
			<h2 id="city-cta-title" class="section__title">{title}</h2>
			<p class="section__lead">{text}</p>
			<div class="city-cta__actions">
				<Button href={primaryHref} size="lg">Gratis offertes aanvragen</Button>
				<Button href={whatsappHref} variant="ghost" size="lg" target="_blank" rel="noopener noreferrer">
					WhatsApp ons
				</Button>
			</div>
		</div>
	</div>
</section>

<style>
	.city-cta {
		padding-top: 0;
	}

	.city-cta__panel {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		min-height: clamp(22rem, 42vw, 28rem);
		padding: clamp(2.5rem, 6vw, 4.25rem);
		border-radius: var(--radius-lg);
		border: 1px solid color-mix(in srgb, var(--color-primary) 45%, transparent);
		box-shadow: var(--shadow-soft);
	}

	.city-cta__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.city-cta__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.city-cta__veil {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			115deg,
			rgba(0, 0, 0, 0.9) 0%,
			rgba(0, 0, 0, 0.75) 55%,
			rgba(18, 14, 8, 0.7) 100%
		);
	}

	.city-cta__content {
		max-width: 40rem;
	}

	.city-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.7rem;
	}

	@media (max-width: 640px) {
		.city-cta__actions :global(.btn) {
			width: 100%;
		}
	}
</style>
