---
import CityIcon from './CityIcon.astro';
import type { CityActivity } from '../../data/cities/types';

interface Props {
	title: string;
	lead: string;
	items: readonly CityActivity[];
}

const { title, lead, items } = Astro.props;
---

<section class="section" aria-labelledby="city-act-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Activiteiten</p>
			<h2 id="city-act-title" class="section__title">{title}</h2>
			<p class="section__lead">{lead}</p>
		</div>
		<div class="city-act__grid">
			{
				items.map((item) => (
					<article class="city-act__card reveal">
						<span class="city-act__icon">
							<CityIcon name={item.icon ?? 'nightlife'} />
						</span>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.city-act__grid {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 700px) {
		.city-act__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.city-act__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.city-act__card {
		padding: 1.3rem 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
		height: 100%;
	}

	.city-act__icon {
		display: inline-grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		margin-bottom: 0.75rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-primary) 18%, transparent);
		color: var(--color-primary);
	}

	.city-act__card h3 {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		color: var(--color-primary);
	}

	.city-act__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.6;
		font-size: 0.96rem;
	}
</style>
