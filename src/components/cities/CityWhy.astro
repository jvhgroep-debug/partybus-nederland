---
import CityIcon from './CityIcon.astro';
import type { CityWhyItem } from '../../data/cities/types';

interface Props {
	title: string;
	lead?: string;
	items: readonly CityWhyItem[];
}

const { title, lead, items } = Astro.props;
---

<section class="section" aria-labelledby="city-why-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Voordelen</p>
			<h2 id="city-why-title" class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
		</div>
		<div class="city-why__grid">
			{
				items.map((item) => (
					<article class="city-why__card reveal">
						<span class="city-why__icon">
							<CityIcon name={item.icon ?? 'group'} />
						</span>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.city-why__grid {
		display: grid;
		gap: 1.15rem;
	}

	@media (min-width: 700px) {
		.city-why__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.city-why__card {
		height: 100%;
		padding: 1.45rem 1.3rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.city-why__icon {
		display: inline-grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		margin-bottom: 0.85rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-primary) 18%, transparent);
		color: var(--color-primary);
	}

	.city-why__card h3 {
		margin: 0 0 0.5rem;
		font-family: var(--font-display);
		font-size: 1.12rem;
		color: var(--color-primary);
	}

	.city-why__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}
</style>
