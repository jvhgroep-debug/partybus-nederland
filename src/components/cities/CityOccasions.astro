---
import type { CityOccasion } from '../../data/cities/types';

interface Props {
	title: string;
	lead?: string;
	items: readonly CityOccasion[];
}

const { title, lead, items } = Astro.props;

const occasionPaths: Record<string, string> = {
	Vrijgezellenfeest: '/diensten/partybus-vrijgezellenfeest/',
	Bruiloft: '/diensten/partybus-bruiloft/',
	Bedrijfsuitje: '/diensten/partybus-bedrijfsuitje/',
	Verjaardag: '/diensten/partybus-verjaardag/',
	Schoolfeest: '/diensten/partybus-schoolfeest/',
	Gala: '/diensten/partybus-gala/',
};
---

<section class="section" aria-labelledby="city-occ-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Gelegenheden</p>
			<h2 id="city-occ-title" class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
		</div>
		<div class="city-occ__grid">
			{
				items.map((item) => (
					<article class="city-occ__card reveal">
						<a href={occasionPaths[item.title] ?? '/gratis-partybus-offertes-aanvragen/'}>
							<img src={item.image} alt="" width="900" height="600" loading="lazy" decoding="async" />
							<div class="city-occ__body">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
								<span>Bekijk mogelijkheden →</span>
							</div>
						</a>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.city-occ__grid {
		display: grid;
		gap: 1.15rem;
		align-items: stretch;
	}

	@media (min-width: 700px) {
		.city-occ__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.city-occ__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.city-occ__card {
		overflow: hidden;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: #0a0a0a;
		height: 100%;
		display: flex;
		flex-direction: column;
		transition:
			transform 0.35s var(--ease-out),
			box-shadow 0.35s var(--ease-out);
	}

	.city-occ__card > a {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.city-occ__card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-soft);
	}

	.city-occ__card img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.city-occ__body {
		padding: 1.15rem 1.2rem 1.35rem;
		flex: 1;
	}

	.city-occ__body h3 {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		color: var(--color-primary);
	}

	.city-occ__body p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.6;
	}

	.city-occ__body span {
		display: inline-block;
		margin-top: 0.75rem;
		color: var(--color-primary);
		font-weight: 700;
		font-size: 0.9rem;
	}
</style>
