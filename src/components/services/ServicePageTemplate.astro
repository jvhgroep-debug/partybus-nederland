---
import type { ServicePage } from '../../data/services/pages';
import { quotePath, servicePages } from '../../data/services/pages';
import { whatsapp } from '../../data/settings/whatsapp';
import Button from '../buttons/Button.astro';
import QuoteForm from '../forms/QuoteForm.astro';
import GuideFaqList from '../guides/GuideFaqList.astro';

interface Props {
	service: ServicePage;
}

const { service } = Astro.props;
const related = servicePages.filter((item) => item.slug !== service.slug).slice(0, 4);
---

<article class="service-page">
	<header class="service-hero">
		<div class="service-hero__media" aria-hidden="true">
			<img
				src={service.image}
				alt=""
				width="1536"
				height="1024"
				fetchpriority="high"
				decoding="async"
			/>
			<div class="service-hero__veil"></div>
		</div>
		<div class="service-hero__content section__inner">
			<nav class="service-hero__breadcrumbs" aria-label="Broodkruimel">
				<a href="/">Home</a><span aria-hidden="true">/</span>
				<a href="/#diensten">Diensten</a><span aria-hidden="true">/</span>
				<span aria-current="page">{service.eyebrow}</span>
			</nav>
			<p class="section__eyebrow">{service.eyebrow}</p>
			<h1>{service.h1}</h1>
			<p>{service.lead}</p>
			<div class="service-hero__actions">
				<Button href={quotePath} size="lg">Vergelijk gratis offertes</Button>
				<Button href={whatsapp.href} variant="ghost" size="lg" target="_blank" rel="noopener noreferrer">
					Direct via WhatsApp
				</Button>
			</div>
			<ul class="service-hero__trust" aria-label="Voordelen">
				<li>Gratis en vrijblijvend</li>
				<li>Meerdere aanbieders vergelijken</li>
				<li>Landelijke dekking</li>
			</ul>
		</div>
	</header>

	<section class="section" aria-labelledby="service-benefits-title">
		<div class="section__inner">
			<div class="section__head reveal">
				<p class="section__eyebrow">Voordelen</p>
				<h2 id="service-benefits-title" class="section__title">Waarom een partybus voor {service.eyebrow.toLowerCase()}?</h2>
				<p class="section__lead">
					De rit is meer dan vervoer: je houdt de groep bij elkaar en stemt voertuig, route en sfeer af op jullie plannen.
				</p>
			</div>
			<div class="service-cards">
				{service.benefits.map((benefit) => (
					<article class="service-card reveal">
						<span aria-hidden="true">✓</span>
						<h3>{benefit.title}</h3>
						<p>{benefit.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section service-fit" aria-labelledby="service-fit-title">
		<div class="section__inner service-fit__grid">
			<div class="reveal">
				<p class="section__eyebrow">Toepassingen</p>
				<h2 id="service-fit-title" class="section__title">Geschikt voor jullie programma</h2>
				<p class="section__lead">
					Geef bij je aanvraag aan welke uitvoering je zoekt. Aanbieders kunnen dan gericht reageren.
				</p>
				<ul>
					{service.idealFor.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<figure class="service-fit__media reveal">
				<img
					src={service.image}
					alt={service.imageAlt}
					width="1536"
					height="1024"
					loading="lazy"
					decoding="async"
				/>
			</figure>
		</div>
	</section>

	<section class="section" aria-labelledby="service-how-title">
		<div class="section__inner">
			<div class="section__head reveal">
				<p class="section__eyebrow">Zo werkt vergelijken</p>
				<h2 id="service-how-title" class="section__title">Van aanvraag naar passende partybus</h2>
			</div>
			<ol class="service-steps">
				{service.planning.map((step, index) => (
					<li class="service-step reveal">
						<span>{index + 1}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	<section class="section service-safety" aria-labelledby="service-safety-title">
		<div class="section__inner service-safety__panel reveal">
			<div>
				<p class="section__eyebrow">Veilig en duidelijk geregeld</p>
				<h2 id="service-safety-title" class="section__title">Controleer meer dan alleen de prijs</h2>
			</div>
			<div>
				<p>{service.safetyText}</p>
				<p>
					Vergelijk capaciteit, voorwaarden, inbegrepen faciliteiten en afspraken over route en tijden.
					De uitvoerende aanbieder bevestigt wat voor jouw rit mogelijk is.
				</p>
				<a href="/gidsen/partybus-veiligheid/">Lees de veiligheidsgids →</a>
			</div>
		</div>
	</section>

	<GuideFaqList
		title={`Veelgestelde vragen over ${service.eyebrow.toLowerCase()}`}
		lead="Praktische antwoorden voor je een aanvraag verstuurt."
		items={service.faqs}
	/>

	<section class="section service-related" aria-labelledby="service-related-title">
		<div class="section__inner">
			<div class="section__head reveal">
				<p class="section__eyebrow">Andere gelegenheden</p>
				<h2 id="service-related-title" class="section__title">Bekijk ook deze partybusdiensten</h2>
			</div>
			<div class="service-related__grid">
				{related.map((item) => (
					<a class="service-related__link reveal" href={item.path}>
						<span>{item.eyebrow}</span>
						<strong>{item.h1}</strong>
						<small>Bekijk mogelijkheden →</small>
					</a>
				))}
			</div>
		</div>
	</section>

	<section id="offerte" class="section service-quote" aria-labelledby="service-quote-title">
		<div class="section__inner service-quote__panel reveal">
			<div>
				<p class="section__eyebrow">Gratis aanvraag</p>
				<h2 id="service-quote-title" class="section__title">Vergelijk partybussen voor jullie {service.eyebrow.toLowerCase()}</h2>
				<p class="section__lead">
					Deel je datum, route en groepsgrootte. Je aanvraag is gratis en verplicht je niet om te boeken.
				</p>
				<a class="service-quote__whatsapp" href={whatsapp.href} target="_blank" rel="noopener noreferrer">
					Liever overleggen? WhatsApp ons →
				</a>
			</div>
			<QuoteForm sourcePage={service.path} />
		</div>
	</section>
</article>

<style>
	.service-hero {
		position: relative;
		isolation: isolate;
		min-height: min(48rem, 92vh);
		display: grid;
		align-items: center;
		overflow: hidden;
	}

	.service-hero__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.service-hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.service-hero__veil {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(0, 0, 0, 0.94), rgba(0, 0, 0, 0.66) 62%, rgba(0, 0, 0, 0.42));
	}

	.service-hero__content {
		padding-top: calc(var(--header-height) + 4rem);
		padding-bottom: 4rem;
	}

	.service-hero__breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1.5rem;
		font-size: 0.86rem;
		color: var(--color-text-muted);
	}

	.service-hero__breadcrumbs a:hover {
		color: var(--color-primary);
	}

	.service-hero h1 {
		margin: 0 0 1rem;
		max-width: 13ch;
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 6vw, 4.8rem);
		line-height: 1.03;
		letter-spacing: -0.04em;
	}

	.service-hero__content > p:not(.section__eyebrow) {
		max-width: 39rem;
		margin: 0;
		font-size: clamp(1.1rem, 2vw, 1.3rem);
		color: color-mix(in srgb, var(--color-text) 88%, transparent);
	}

	.service-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.8rem;
	}

	.service-hero__trust {
		margin: 1.4rem 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem 1.4rem;
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.service-hero__trust li::before {
		content: '✓';
		margin-right: 0.4rem;
		color: var(--color-primary);
		font-weight: 800;
	}

	.service-cards,
	.service-related__grid {
		display: grid;
		gap: 1rem;
	}

	.service-card,
	.service-step,
	.service-related__link {
		padding: 1.45rem;
		border: 1px solid var(--color-primary-line);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.service-card > span,
	.service-step > span {
		display: inline-grid;
		place-items: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 999px;
		background: var(--color-primary);
		color: #111;
		font-weight: 800;
	}

	.service-card h3,
	.service-step h3 {
		margin: 0.8rem 0 0.4rem;
		font-family: var(--font-display);
	}

	.service-card p,
	.service-step p {
		margin: 0;
		color: var(--color-text-muted);
	}

	.service-fit {
		background: color-mix(in srgb, var(--color-primary) 5%, transparent);
	}

	.service-fit__grid,
	.service-safety__panel,
	.service-quote__panel {
		display: grid;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	.service-fit ul {
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.75rem;
	}

	.service-fit li::before {
		content: '✓';
		margin-right: 0.65rem;
		color: var(--color-primary);
		font-weight: 800;
	}

	.service-fit__media {
		margin: 0;
		overflow: hidden;
		aspect-ratio: 4 / 3;
		border: 1px solid var(--color-primary-line);
		border-radius: var(--radius-lg);
	}

	.service-fit__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.service-steps {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 1rem;
	}

	.service-safety {
		padding-top: 0;
	}

	.service-safety__panel,
	.service-quote__panel {
		padding: clamp(1.75rem, 5vw, 3.5rem);
		border: 1px solid color-mix(in srgb, var(--color-primary) 45%, transparent);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 12%, #080808), #080808);
	}

	.service-safety p {
		color: var(--color-text-muted);
	}

	.service-safety a,
	.service-quote__whatsapp {
		color: var(--color-primary);
		font-weight: 700;
	}

	.service-related__link {
		display: grid;
		gap: 0.35rem;
		transition: transform 0.25s var(--ease-out), border-color 0.25s var(--ease-out);
	}

	.service-related__link:hover {
		transform: translateY(-3px);
		border-color: var(--color-primary);
	}

	.service-related__link span,
	.service-related__link small {
		color: var(--color-primary);
	}

	.service-related__link strong {
		font-family: var(--font-display);
		font-size: 1.1rem;
	}

	.service-quote {
		padding-top: 0;
	}

	.service-quote__whatsapp {
		display: inline-block;
		margin-top: 1.2rem;
	}

	@media (min-width: 760px) {
		.service-cards,
		.service-steps {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.service-related__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.service-fit__grid,
		.service-safety__panel,
		.service-quote__panel {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.service-hero {
			min-height: 42rem;
		}

		.service-hero__actions :global(.btn) {
			width: 100%;
		}

		.service-hero__trust {
			display: grid;
		}
	}
</style>
