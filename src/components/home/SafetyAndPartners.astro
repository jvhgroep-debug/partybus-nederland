---
import Button from '../buttons/Button.astro';
---

<section class="section assurance" aria-labelledby="assurance-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Luxe, veiligheid en gemak</p>
			<h2 id="assurance-title" class="section__title">Vergelijk met vertrouwen</h2>
			<p class="section__lead">
				Een goede keuze gaat verder dan de laagste prijs. Controleer wat je krijgt en leg belangrijke afspraken vast.
			</p>
		</div>

		<div class="assurance__grid">
			<article class="assurance__card reveal">
				<span aria-hidden="true">01</span>
				<h3>Passende capaciteit</h3>
				<p>Vergelijk het aantal zit- en staanplaatsen en controleer of de bus past bij jullie groepsgrootte.</p>
			</article>
			<article class="assurance__card reveal">
				<span aria-hidden="true">02</span>
				<h3>Duidelijke ritafspraken</h3>
				<p>Leg route, opstapplaatsen, wachttijd, terugrit en contactpersonen vooraf duidelijk vast.</p>
			</article>
			<article class="assurance__card reveal">
				<span aria-hidden="true">03</span>
				<h3>Voorwaarden en veiligheid</h3>
				<p>Vraag naar huisregels, verzekeringen, chauffeursafspraken en wat wel of niet bij het voorstel hoort.</p>
			</article>
			<article class="assurance__card reveal">
				<span aria-hidden="true">04</span>
				<h3>Luxe die bij je past</h3>
				<p>Vergelijk interieur, verlichting, geluidsinstallatie, bagageruimte en eventuele extra wensen.</p>
			</article>
		</div>

		<div class="assurance__partners reveal">
			<div>
				<p class="section__eyebrow">Voor partybusbedrijven</p>
				<h2 class="section__title">Ontvang relevante aanvragen uit jouw regio</h2>
				<p class="section__lead">
					Verhuur je partybussen? Sluit aan bij het netwerk en reageer op aanvragen die passen bij jouw wagenpark en werkgebied.
				</p>
			</div>
			<Button href="/contact/" variant="ghost" size="lg">Aanmelden als aanbieder</Button>
		</div>
	</div>
</section>

<style>
	.assurance {
		background: color-mix(in srgb, var(--color-primary) 4%, transparent);
	}

	.assurance__grid {
		display: grid;
		gap: 1rem;
	}

	.assurance__card {
		padding: 1.4rem;
		border: 1px solid var(--color-primary-line);
		border-radius: var(--radius-md);
		background: #090909;
	}

	.assurance__card > span {
		font-family: var(--font-display);
		color: var(--color-primary);
		font-weight: 800;
	}

	.assurance__card h3 {
		margin: 0.65rem 0 0.4rem;
		font-family: var(--font-display);
	}

	.assurance__card p {
		margin: 0;
		color: var(--color-text-muted);
	}

	.assurance__partners {
		margin-top: clamp(2rem, 5vw, 3.5rem);
		padding: clamp(1.5rem, 4vw, 2.5rem);
		display: grid;
		gap: 1.5rem;
		align-items: center;
		border: 1px solid color-mix(in srgb, var(--color-primary) 45%, transparent);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 12%, #080808), #080808);
	}

	.assurance__partners .section__title {
		font-size: clamp(1.6rem, 3vw, 2.35rem);
	}

	@media (min-width: 700px) {
		.assurance__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.assurance__partners {
			grid-template-columns: 1fr auto;
		}
	}

	@media (min-width: 1050px) {
		.assurance__grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.assurance__partners :global(.btn) {
			width: 100%;
		}
	}
</style>
