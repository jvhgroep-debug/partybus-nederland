---
import { popularCities } from '../../data/cities/popular';
import { primaryCta } from '../../data/settings/navigation';
import Button from '../buttons/Button.astro';
---

<section id="steden" class="section cities" aria-labelledby="cities-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Populaire steden</p>
			<h2 id="cities-title" class="section__title">Partybus huren bij jou in de buurt</h2>
			<p class="section__lead">
				Start in een van deze populaire steden of vraag direct offertes aan voor jouw
				locatie — door heel Nederland.
			</p>
		</div>

		<div class="cities__grid">
			{
				popularCities.map((city) => (
					<article class="city-card reveal">
						<img
							src={city.image}
							alt={`Partybus huren in ${city.name}`}
							width="1200"
							height="800"
							loading="lazy"
							decoding="async"
						/>
						<div class="city-card__overlay">
							<h3>{city.name}</h3>
							<p>{city.blurb}</p>
							<Button href={primaryCta.href} class="city-card__btn">Offertes aanvragen</Button>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.cities__grid {
		display: grid;
		gap: 1.25rem;
	}

	@media (min-width: 700px) {
		.cities__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.cities__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.city-card {
		position: relative;
		isolation: isolate;
		min-height: 19rem;
		overflow: hidden;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		box-shadow: var(--shadow-card);
		background: #111;
		transition:
			transform 0.4s var(--ease-out),
			box-shadow 0.4s var(--ease-out);
	}

	.city-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-soft);
	}

	.city-card img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.85s var(--ease-out);
		z-index: -2;
	}

	.city-card::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 8%, rgba(0, 0, 0, 0.88) 100%);
	}

	.city-card:hover img {
		transform: scale(1.07);
	}

	.city-card__overlay {
		height: 100%;
		min-height: 19rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		align-items: flex-start;
		padding: 1.4rem;
		gap: 0.45rem;
	}

	.city-card__overlay h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.55rem;
		font-weight: 800;
	}

	.city-card__overlay p {
		margin: 0 0 0.55rem;
		color: var(--color-text-muted);
		font-size: 0.98rem;
		line-height: 1.55;
		max-width: 28ch;
	}

	.city-card__btn {
		min-height: 2.45rem;
		padding: 0.55rem 1rem;
		font-size: 0.86rem;
	}
</style>