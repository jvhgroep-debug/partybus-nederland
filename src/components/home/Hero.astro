---
import { site } from '../../data/settings/site';
import { primaryCta } from '../../data/settings/navigation';
import Button from '../buttons/Button.astro';

interface Props {
	brand?: string;
	title?: string;
	subtitle?: string;
	image?: string;
	imageWidth?: number;
	imageHeight?: number;
	primaryHref?: string;
	primaryLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
	showScroll?: boolean;
	scrollHref?: string;
	titleId?: string;
	/** Homepage default: center. Guide pages: start (left text block, max ~600px). */
	align?: 'center' | 'start';
}

const {
	brand = site.name,
	title = 'Partybus huren in Nederland',
	subtitle = 'Tips, bestemmingen en prijzen uitgelegd — daarna gratis meerdere offertes vergelijken.',
	image = '/images/hero-partybus.png',
	imageWidth = 1536,
	imageHeight = 1024,
	primaryHref = primaryCta.href,
	primaryLabel = 'Gratis offertes aanvragen',
	secondaryHref = '/gids/partybus-huren/',
	secondaryLabel = 'Lees de gids',
	showScroll = true,
	scrollHref = '#vertrouwen',
	titleId = 'hero-title',
	align = 'center',
} = Astro.props;
---

<section class:list={['hero', align === 'start' && 'hero--start']} aria-labelledby={titleId}>
	<div class="hero__media" aria-hidden="true">
		<img
			src={image}
			alt=""
			width={imageWidth}
			height={imageHeight}
			loading="eager"
			fetchpriority="high"
			decoding="async"
		/>
		<div class="hero__veil"></div>
	</div>

	<div class="hero__content section__inner">
		<p class="hero__brand">{brand}</p>
		<h1 id={titleId} class="hero__title">{title}</h1>
		<p class="hero__subtitle">{subtitle}</p>
		<div class="hero__actions">
			<Button href={primaryHref} size="lg">{primaryLabel}</Button>
			{
				secondaryHref && secondaryLabel && (
					<Button href={secondaryHref} variant="ghost" size="lg">
						{secondaryLabel}
					</Button>
				)
			}
		</div>
	</div>

	{
		showScroll && (
			<a class="hero__scroll" href={scrollHref} aria-label="Scroll naar inhoud">
				<span class="hero__scroll-label">Scroll</span>
				<span class="hero__scroll-line" aria-hidden="true"></span>
			</a>
		)
	}
</section>

<style>
	.hero {
		position: relative;
		isolation: isolate;
		min-height: 85vh;
		min-height: 85dvh;
		display: grid;
		place-items: center;
		overflow: hidden;
		background: #000;
		text-align: center;
	}

	.hero--start {
		text-align: left;
	}

	.hero__media {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.hero__media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		max-height: none;
		object-fit: cover;
		object-position: center 45%;
		transform: scale(1.04);
		animation: hero-zoom 20s var(--ease-out) forwards;
	}

	.hero__veil {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background:
			radial-gradient(circle at center, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.72) 72%),
			linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.42) 40%, rgba(0, 0, 0, 0.84) 100%);
	}

	.hero__content {
		position: relative;
		z-index: 2;
		padding-block: clamp(6rem, 12vw, 8rem) clamp(5rem, 10vw, 7rem);
		display: grid;
		justify-items: center;
		width: 100%;
	}

	.hero--start .hero__content {
		justify-items: start;
	}

	.hero__brand {
		margin: 0 0 1.1rem;
		font-family: var(--font-display);
		font-size: clamp(0.95rem, 1.8vw, 1.1rem);
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.hero__title {
		margin: 0 0 1.2rem;
		max-width: 12ch;
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 7.2vw, 5.1rem);
		font-weight: 800;
		line-height: 1.02;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.hero--start .hero__title {
		max-width: 16ch;
	}

	.hero__subtitle {
		margin: 0 0 2rem;
		max-width: 32rem;
		font-size: clamp(1.05rem, 2vw, 1.28rem);
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-text) 92%, transparent);
		text-wrap: pretty;
	}

	.hero--start .hero__subtitle {
		max-width: 37.5rem;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.85rem;
	}

	.hero--start .hero__actions {
		justify-content: flex-start;
	}

	.hero__scroll {
		position: absolute;
		left: 50%;
		bottom: 1.25rem;
		z-index: 2;
		transform: translateX(-50%);
		display: grid;
		justify-items: center;
		gap: 0.45rem;
		color: color-mix(in srgb, var(--color-text) 75%, transparent);
		font-family: var(--font-display);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.hero__scroll-line {
		width: 1px;
		height: 2.4rem;
		background: linear-gradient(180deg, var(--color-primary), transparent);
		animation: scroll-pulse 1.8s var(--ease-out) infinite;
	}

	@keyframes hero-zoom {
		from { transform: scale(1.1); }
		to { transform: scale(1.04); }
	}

	@keyframes scroll-pulse {
		0%, 100% { transform: scaleY(1); opacity: 0.45; }
		50% { transform: scaleY(1.15); opacity: 1; }
	}

	@media (max-width: 640px) {
		.hero__actions {
			width: 100%;
		}

		.hero__actions :global(.btn) {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__media img,
		.hero__scroll-line {
			animation: none;
		}
	}
</style>
