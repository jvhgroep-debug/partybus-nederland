---
import { site } from '../../data/settings/site';
import { primaryCta } from '../../data/settings/navigation';
import Button from '../buttons/Button.astro';
---

<section class="hero" aria-labelledby="hero-title">
	<div class="hero__media" aria-hidden="true">
		<img
			src="/images/hero-partybus.png"
			alt=""
			width="1536"
			height="1024"
			fetchpriority="high"
			decoding="async"
		/>
		<div class="hero__veil"></div>
	</div>

	<div class="hero__content section__inner">
		<p class="hero__brand">{site.name}</p>
		<h1 id="hero-title" class="hero__title">Partybus huren in Nederland</h1>
		<p class="hero__subtitle">
			Vergelijk gratis meerdere aanbieders en ontvang snel de beste offerte.
		</p>
		<div class="hero__actions">
			<Button href={primaryCta.href} size="lg">Gratis offertes aanvragen</Button>
			<Button href="/#steden" variant="ghost" size="lg">Bekijk alle steden</Button>
		</div>
	</div>

	<a class="hero__scroll" href="#vertrouwen" aria-label="Scroll naar inhoud">
		<span class="hero__scroll-label">Scroll</span>
		<span class="hero__scroll-line" aria-hidden="true"></span>
	</a>
</section>

<style>
	.hero {
		position: relative;
		isolation: isolate;
		min-height: 85vh;
		min-height: 85dvh;
		display: grid;
		place-items: center;
		overflow: hidden;
		background: #000;
		text-align: center;
	}

	.hero__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 45%;
		transform: scale(1.04);
		animation: hero-zoom 20s var(--ease-out) forwards;
	}

	.hero__veil {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at center, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.72) 72%),
			linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.42) 40%, rgba(0, 0, 0, 0.84) 100%);
	}

	.hero__content {
		padding-block: clamp(6rem, 12vw, 8rem) clamp(5rem, 10vw, 7rem);
		display: grid;
		justify-items: center;
	}

	.hero__brand {
		margin: 0 0 1.1rem;
		font-family: var(--font-display);
		font-size: clamp(0.95rem, 1.8vw, 1.1rem);
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.hero__title {
		margin: 0 0 1.2rem;
		max-width: 12ch;
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 7.2vw, 5.1rem);
		font-weight: 800;
		line-height: 1.02;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.hero__subtitle {
		margin: 0 0 2rem;
		max-width: 32rem;
		font-size: clamp(1.05rem, 2vw, 1.28rem);
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-text) 92%, transparent);
		text-wrap: pretty;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.85rem;
	}

	.hero__scroll {
		position: absolute;
		left: 50%;
		bottom: 1.25rem;
		transform: translateX(-50%);
		display: grid;
		justify-items: center;
		gap: 0.45rem;
		color: color-mix(in srgb, var(--color-text) 75%, transparent);
		font-family: var(--font-display);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.hero__scroll-line {
		width: 1px;
		height: 2.4rem;
		background: linear-gradient(180deg, var(--color-primary), transparent);
		animation: scroll-pulse 1.8s var(--ease-out) infinite;
	}

	@keyframes hero-zoom {
		from { transform: scale(1.1); }
		to { transform: scale(1.04); }
	}

	@keyframes scroll-pulse {
		0%, 100% { transform: scaleY(1); opacity: 0.45; }
		50% { transform: scaleY(1.15); opacity: 1; }
	}

	@media (max-width: 640px) {
		.hero__actions {
			width: 100%;
		}

		.hero__actions :global(.btn) {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__media img,
		.hero__scroll-line {
			animation: none;
		}
	}
</style>