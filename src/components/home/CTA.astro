---
import { primaryCta } from '../../data/settings/navigation';
import Button from '../buttons/Button.astro';
---

<section id="offerte" class="section cta" aria-labelledby="cta-title">
	<div class="cta__panel section__inner reveal">
		<div class="cta__media" aria-hidden="true">
			<img
				src="/images/partybus-arena.png"
				alt=""
				width="1672"
				height="941"
				loading="lazy"
				decoding="async"
			/>
			<div class="cta__veil"></div>
		</div>
		<div class="cta__content">
			<p class="section__eyebrow">Klaar om te vergelijken?</p>
			<h2 id="cta-title" class="section__title">Vraag vandaag nog gratis offertes aan</h2>
			<p class="section__lead">
				Ontvang voorstellen van meerdere partybus-aanbieders en kies zelf de beste deal voor
				jouw feest — vrijblijvend en door heel Nederland.
			</p>
			<div class="cta__actions">
				<Button href={primaryCta.href} size="lg" class="cta__btn">Gratis offertes aanvragen</Button>
				<Button href="/#steden" variant="ghost" size="lg">Bekijk populaire steden</Button>
			</div>
		</div>
	</div>
</section>

<style>
	.cta {
		padding-top: 0;
	}

	.cta__panel {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		min-height: 22rem;
		padding: clamp(2.25rem, 6vw, 4.25rem);
		border-radius: var(--radius-lg);
		border: 1px solid color-mix(in srgb, var(--color-primary) 48%, transparent);
		box-shadow: var(--shadow-soft);
		display: grid;
		align-items: center;
	}

	.cta__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.cta__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.cta__veil {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(115deg, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.78) 48%, rgba(18, 14, 8, 0.72) 100%),
			radial-gradient(600px 260px at 20% 20%, color-mix(in srgb, var(--color-primary) 28%, transparent), transparent 70%);
	}

	.cta__content {
		max-width: 40rem;
	}

	.cta__panel .section__title {
		max-width: 16ch;
	}

	.cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 1.9rem;
	}

	.cta__btn {
		box-shadow: 0 16px 42px color-mix(in srgb, var(--color-primary) 45%, transparent);
		animation: cta-glow 2.8s ease-in-out infinite;
	}

	@keyframes cta-glow {
		0%, 100% { box-shadow: 0 14px 34px color-mix(in srgb, var(--color-primary) 35%, transparent); }
		50% { box-shadow: 0 18px 48px color-mix(in srgb, var(--color-primary) 55%, transparent); }
	}

	@media (max-width: 640px) {
		.cta__actions {
			width: 100%;
		}

		.cta__actions :global(.btn) {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cta__btn {
			animation: none;
		}
	}
</style>