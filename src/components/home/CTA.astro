---
import QuoteForm from '../forms/QuoteForm.astro';
---

<section id="offerte" class="section cta" aria-labelledby="cta-title">
	<div class="cta__panel section__inner reveal">
		<div class="cta__media" aria-hidden="true">
			<img
				src="/images/partybus-arena.png"
				alt=""
				width="1672"
				height="941"
				loading="lazy"
				decoding="async"
			/>
			<div class="cta__veil"></div>
		</div>
		<div class="cta__layout">
			<div class="cta__content">
				<p class="section__eyebrow">Klaar om te vergelijken?</p>
				<h2 id="cta-title" class="section__title">Ontdek welke partybus bij jullie past</h2>
				<p class="section__lead">
					Vul één keer je wensen in en vergelijk reacties van passende aanbieders.
					Je aanvraag is gratis en je zit nergens aan vast.
				</p>
				<ul class="cta__trust">
					<li>Vergelijk meerdere voorstellen</li>
					<li>Beschikbaar voor groepen tot 80 personen</li>
					<li>Ritten door Nederland en België</li>
				</ul>
			</div>
			<div class="cta__form">
				<QuoteForm sourcePage="/" />
			</div>
		</div>
	</div>
</section>

<style>
	.cta {
		padding-top: 0;
	}

	.cta__panel {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: clamp(2.25rem, 6vw, 4.25rem);
		border-radius: var(--radius-lg);
		border: 1px solid color-mix(in srgb, var(--color-primary) 48%, transparent);
		box-shadow: var(--shadow-soft);
	}

	.cta__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.cta__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.cta__veil {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(115deg, rgba(0, 0, 0, 0.94) 0%, rgba(0, 0, 0, 0.86) 48%, rgba(18, 14, 8, 0.82) 100%),
			radial-gradient(600px 260px at 20% 20%, color-mix(in srgb, var(--color-primary) 22%, transparent), transparent 70%);
	}

	.cta__layout {
		display: grid;
		gap: 2rem;
	}

	@media (min-width: 960px) {
		.cta__layout {
			grid-template-columns: 0.9fr 1.1fr;
			gap: 2.75rem;
			align-items: start;
		}
	}

	.cta__content {
		max-width: 32rem;
	}

	.cta__panel .section__title {
		max-width: 16ch;
	}

	.cta__trust {
		margin: 1.4rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.55rem;
		color: var(--color-text-muted);
	}

	.cta__trust li::before {
		content: '✓';
		margin-right: 0.55rem;
		color: var(--color-primary);
		font-weight: 800;
	}

	.cta__form {
		width: 100%;
	}
</style>
