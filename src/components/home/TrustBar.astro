---
const items = [
	{
		label: 'Gratis offertes',
		icon: 'gift',
	},
	{
		label: 'Binnen 24 uur reactie',
		icon: 'clock',
	},
	{
		label: 'Heel Nederland',
		icon: 'map',
	},
	{
		label: 'Meerdere aanbieders',
		icon: 'users',
	},
];
---

<section id="vertrouwen" class="trust" aria-label="Voordelen">
	<div class="section__inner">
		<ul class="trust__list">
			{
				items.map((item) => (
					<li class="trust__item reveal">
						<span class="trust__icon" aria-hidden="true">
							{item.icon === 'gift' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
									<path d="M12 8v13M4 12h16M5 8h14v13H5V8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
									<path d="M12 8c-2-3.5-6-3-6-1s2.2 2.4 6 1zm0 0c2-3.5 6-3 6-1s-2.2 2.4-6 1z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
								</svg>
							)}
							{item.icon === 'clock' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
									<circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.8" />
									<path d="M12 8v5l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
								</svg>
							)}
							{item.icon === 'map' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
									<path d="M9 4l-5 2v14l5-2 6 2 5-2V4l-5 2-6-2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
									<path d="M9 4v14M15 6v14" stroke="currentColor" stroke-width="1.8" />
								</svg>
							)}
							{item.icon === 'users' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
									<path d="M16 19v-1.2A3.8 3.8 0 0012.2 14H7.8A3.8 3.8 0 004 17.8V19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
									<circle cx="10" cy="8" r="3" stroke="currentColor" stroke-width="1.8" />
									<path d="M20 19v-1.1A3.2 3.2 0 0017 14.8M16 5.2a3 3 0 010 5.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
								</svg>
							)}
						</span>
						<span class="trust__label">{item.label}</span>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.trust {
		border-block: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 8%, transparent);
		padding-block: clamp(1.5rem, 3vw, 2.1rem);
	}

	.trust__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 1rem 1.35rem;
	}

	@media (min-width: 700px) {
		.trust__list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1000px) {
		.trust__list {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	.trust__item {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		padding: 0.35rem 0;
	}

	.trust__icon {
		display: inline-grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 999px;
		color: #111;
		background: var(--color-primary);
		flex-shrink: 0;
		box-shadow: 0 8px 20px color-mix(in srgb, var(--color-primary) 30%, transparent);
	}

	.trust__label {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1rem;
		line-height: 1.35;
	}
</style>