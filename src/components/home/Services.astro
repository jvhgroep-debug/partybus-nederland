---
import { services } from '../../data/settings/services';
---

<section id="diensten" class="section services" aria-labelledby="services-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">Onze diensten</p>
			<h2 id="services-title" class="section__title">Voor elk feest de juiste partybus</h2>
			<p class="section__lead">
				Van intieme verjaardag tot groots vrijgezellenfeest: vraag offertes aan die
				passen bij jouw gelegenheid.
			</p>
		</div>

		<div class="services__grid">
			{
				services.map((service) => (
					<article class="service-card reveal">
						<div class="service-card__media">
							<img
								src={service.image}
								alt=""
								width="800"
								height="600"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="service-card__body">
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services__grid {
		display: grid;
		gap: 1.35rem;
		align-items: stretch;
	}

	@media (min-width: 700px) {
		.services__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.services__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.service-card {
		height: 100%;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
		box-shadow: var(--shadow-card);
		transition:
			transform 0.4s var(--ease-out),
			border-color 0.4s var(--ease-out),
			box-shadow 0.4s var(--ease-out);
	}

	.service-card:hover {
		transform: translateY(-6px);
		border-color: color-mix(in srgb, var(--color-primary) 60%, transparent);
		box-shadow: var(--shadow-soft);
	}

	.service-card__media {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		flex-shrink: 0;
	}

	.service-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.75s var(--ease-out);
	}

	.service-card:hover .service-card__media img {
		transform: scale(1.07);
	}

	.service-card__body {
		padding: 1.35rem 1.35rem 1.55rem;
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: 0.55rem;
	}

	.service-card__body h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 700;
		color: var(--color-primary);
	}

	.service-card__body p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.65;
	}
</style>