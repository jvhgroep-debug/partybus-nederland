---
import { site } from '../../data/settings/site';
import { mainNav, primaryCta } from '../../data/settings/navigation';
import Button from '../buttons/Button.astro';
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="site-header__brand" href="/">{site.name}</a>

		<nav class="site-header__nav" data-nav aria-label="Hoofdnavigatie">
			{
				mainNav.map((item) => (
					<a href={item.href}>{item.label}</a>
				))
			}
		</nav>

		<div class="site-header__actions">
			<Button href={primaryCta.href} class="site-header__cta">{primaryCta.label}</Button>
			<button
				class="site-header__toggle"
				type="button"
				aria-expanded="false"
				aria-controls="mobile-nav"
				data-nav-toggle
			>
				<span class="sr-only">Menu</span>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
			</button>
		</div>
	</div>

	<nav id="mobile-nav" class="site-header__mobile" data-mobile-nav aria-label="Mobiel menu" hidden>
		{
			mainNav.map((item) => (
				<a href={item.href} data-mobile-link>
					{item.label}
				</a>
			))
		}
		<Button href={primaryCta.href} class="site-header__mobile-cta">{primaryCta.label}</Button>
	</nav>
</header>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.site-header {
		position: fixed;
		left: 0;
		right: 0;
		top: 0;
		z-index: 50;
		background: transparent;
		border-bottom: 1px solid transparent;
		transition:
			background-color 0.35s var(--ease-out),
			border-color 0.35s var(--ease-out),
			backdrop-filter 0.35s var(--ease-out),
			box-shadow 0.35s var(--ease-out);
	}

	.site-header.is-scrolled,
	.site-header.is-open {
		background: rgba(0, 0, 0, 0.94);
		backdrop-filter: blur(18px);
		border-bottom-color: var(--color-primary-line);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
	}

	.site-header__inner {
		width: min(100% - 1.5rem, var(--content-max-width));
		min-height: var(--header-height);
		margin-inline: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.site-header__brand {
		font-family: var(--font-display);
		font-size: clamp(0.95rem, 2.4vw, 1.15rem);
		font-weight: 800;
		letter-spacing: 0.02em;
		color: var(--color-primary);
		white-space: nowrap;
	}

	.site-header__nav {
		display: none;
		align-items: center;
		gap: 1.25rem;
		font-size: 0.92rem;
		color: var(--color-text-muted);
	}

	.site-header__nav a {
		white-space: nowrap;
		transition: color 0.2s var(--ease-out);
	}

	.site-header__nav a:hover {
		color: var(--color-primary);
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 0.65rem;
	}

	:global(.site-header__cta) {
		min-height: 2.55rem;
		padding-inline: 1rem;
		font-size: 0.84rem;
	}

	.site-header__toggle {
		display: inline-grid;
		gap: 5px;
		width: 2.55rem;
		height: 2.55rem;
		place-content: center;
		border: 1px solid var(--color-primary-line);
		border-radius: 999px;
		background: transparent;
		cursor: pointer;
		padding: 0;
	}

	.site-header__toggle span:not(.sr-only) {
		display: block;
		width: 1.05rem;
		height: 2px;
		background: var(--color-primary);
		transition: transform 0.25s var(--ease-out), opacity 0.25s var(--ease-out);
	}

	.site-header.is-open .site-header__toggle span:nth-child(2) {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header.is-open .site-header__toggle span:nth-child(3) {
		opacity: 0;
	}

	.site-header.is-open .site-header__toggle span:nth-child(4) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.site-header__mobile {
		display: grid;
		gap: 0.35rem;
		padding: 0.5rem 1.25rem 1.25rem;
		border-top: 1px solid var(--color-primary-line);
	}

	.site-header__mobile[hidden] {
		display: none;
	}

	.site-header__mobile a:not(.btn) {
		padding: 0.85rem 0.25rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 16%, transparent);
		color: var(--color-text);
		font-size: 1.02rem;
	}

	:global(.site-header__mobile-cta) {
		margin-top: 0.75rem;
		width: 100%;
	}

	@media (min-width: 980px) {
		.site-header__nav {
			display: flex;
			margin-left: auto;
			margin-right: 1rem;
		}

		.site-header__toggle,
		.site-header__mobile {
			display: none !important;
		}

		:global(.site-header__cta) {
			min-height: 2.75rem;
			padding-inline: 1.2rem;
			font-size: 0.9rem;
		}
	}

	@media (max-width: 900px) {
		:global(.site-header__cta) {
			display: none !important;
		}
	}
</style>