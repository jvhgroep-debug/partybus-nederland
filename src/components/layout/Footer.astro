---
import { site } from '../../data/settings/site';
import { popularCities } from '../../data/cities/popular';
import { publishedCities } from '../../data/cities/registry';
import { mainNav, primaryCta } from '../../data/settings/navigation';
import { whatsapp } from '../../data/settings/whatsapp';
import { hubGuideLinks } from '../../data/gidsen/shared';
import { gidsenPath } from '../../data/gidsen/registry';
import Button from '../buttons/Button.astro';
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div class="site-footer__brand">
			<p class="site-footer__name">{site.companyName}</p>
			<p class="site-footer__text">
				Complete informatie over partybus huren — tips, bestemmingen en vrijblijvend offertes vergelijken.
			</p>
			<Button href={primaryCta.href} class="site-footer__cta">{primaryCta.label}</Button>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Navigatie</p>
			{mainNav.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Steden</p>
			{publishedCities.slice(0, 6).map((city) => (
				<a href={city.path}>{city.name}</a>
			))}
			<a href="/#steden">Alle steden</a>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Kennisbank</p>
			{hubGuideLinks.slice(0, 5).map((guide) => (
				<a href={gidsenPath(guide.slug)}>{guide.label}</a>
			))}
			<a href="/gidsen/">Alle gidsen</a>
			<a href="/sitemap/">Sitemap</a>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Contact</p>
			<a href="/contact">Contactpagina</a>
			<a href={whatsapp.href} target="_blank" rel="noopener noreferrer">WhatsApp {whatsapp.phoneDisplay}</a>
			<a href={primaryCta.href}>{primaryCta.label}</a>
			<a href="/#faq">Veelgestelde vragen</a>
		</div>
	</div>

	<div class="site-footer__bottom">
		<p>© {new Date().getFullYear()} {site.companyName}. Alle rechten voorbehouden.</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		border-top: 1px solid var(--color-primary-line);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-primary) 8%, transparent), transparent 40%),
			var(--color-surface);
		padding-top: clamp(3.5rem, 7vw, 5.25rem);
	}

	.site-footer__inner {
		width: min(100% - 1.5rem, var(--content-max-width));
		margin-inline: auto;
		display: grid;
		gap: 2.5rem;
	}

	@media (min-width: 640px) {
		.site-footer__inner {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 2.75rem 2rem;
		}
	}

	@media (min-width: 960px) {
		.site-footer__inner {
			grid-template-columns: 1.45fr 1fr 1fr 1fr 1fr;
			gap: 2.5rem;
		}
	}

	.site-footer__name {
		margin: 0 0 0.9rem;
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--color-primary);
	}

	.site-footer__text {
		margin: 0 0 1.25rem;
		max-width: 28rem;
		color: var(--color-text-muted);
		line-height: 1.7;
		font-size: 1rem;
	}

	.site-footer__cta {
		min-height: 2.7rem;
		font-size: 0.9rem;
	}

	.site-footer__heading {
		margin: 0 0 1.1rem;
		font-family: var(--font-display);
		font-size: 0.86rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.site-footer__col {
		display: grid;
		align-content: start;
		gap: 0.9rem;
	}

	.site-footer__col a {
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.45;
		padding-block: 0.15rem;
		transition: color 0.2s var(--ease-out);
	}

	.site-footer__col a:hover {
		color: var(--color-text);
	}

	.site-footer__bottom {
		width: min(100% - 1.5rem, var(--content-max-width));
		margin: 3rem auto 0;
		padding: 1.4rem 0 2rem;
		border-top: 1px solid var(--color-primary-line);
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.site-footer__bottom p {
		margin: 0;
		padding-right: 4.5rem;
	}
</style>