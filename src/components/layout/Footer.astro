---
import { site } from '../../data/settings/site';
import { publishedCities } from '../../data/cities/registry';
import { mainNav, primaryCta } from '../../data/settings/navigation';
import { whatsapp } from '../../data/settings/whatsapp';
import { hubGuideLinks } from '../../data/gidsen/shared';
import { gidsenPath } from '../../data/gidsen/registry';
import { trustNav, footerLegalNav } from '../../data/trust/pages';
import Button from '../buttons/Button.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div class="site-footer__brand">
			<p class="site-footer__name">{site.companyName}</p>
			<p class="site-footer__text">
				Complete informatie over partybus huren — tips, bestemmingen en vrijblijvend offertes vergelijken.
			</p>
			<Button href={primaryCta.href} class="site-footer__cta">{primaryCta.label}</Button>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Navigatie</p>
			{mainNav.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Steden</p>
			{publishedCities.slice(0, 6).map((city) => (
				<a href={city.path}>{city.name}</a>
			))}
			<a href="/#steden">Alle steden</a>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Kennisbank</p>
			{hubGuideLinks.slice(0, 5).map((guide) => (
				<a href={gidsenPath(guide.slug)}>{guide.label}</a>
			))}
			<a href="/gidsen/">Alle gidsen</a>
			<a href="/sitemap/">Sitemap</a>
		</div>

		<div class="site-footer__col">
			<p class="site-footer__heading">Contact</p>
			<a href="/contact/">Contactpagina</a>
			<a href={whatsapp.href} target="_blank" rel="noopener noreferrer">WhatsApp {whatsapp.phoneDisplay}</a>
			<a href={primaryCta.href}>{primaryCta.label}</a>
			<a href="/over-ons/">Over ons</a>
		</div>
	</div>

	<div class="site-footer__bottom">
		<p class="site-footer__copy">© {site.companyName} {year}</p>
		<div class="site-footer__nav-rows">
			<nav class="site-footer__legal" aria-label="Over Partybus Nederland">
				{
					trustNav.map((item, index) => (
						<span class="site-footer__legal-item">
							{index > 0 && <span class="site-footer__sep" aria-hidden="true">·</span>}
							<a href={item.href}>{item.label}</a>
						</span>
					))
				}
			</nav>
			<nav class="site-footer__legal" aria-label="Juridische informatie">
				{
					footerLegalNav.map((item, index) => (
						<span class="site-footer__legal-item">
							{index > 0 && <span class="site-footer__sep" aria-hidden="true">·</span>}
							<a href={item.href}>{item.label}</a>
						</span>
					))
				}
			</nav>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		border-top: 1px solid var(--color-primary-line);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-primary) 8%, transparent), transparent 40%),
			var(--color-surface);
		padding-top: clamp(3.5rem, 7vw, 5.25rem);
	}

	.site-footer__inner {
		width: min(100% - 1.5rem, var(--content-max-width));
		margin-inline: auto;
		display: grid;
		gap: 2.5rem;
	}

	@media (min-width: 640px) {
		.site-footer__inner {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 2.75rem 2rem;
		}
	}

	@media (min-width: 960px) {
		.site-footer__inner {
			grid-template-columns: 1.45fr 1fr 1fr 1fr 1fr;
			gap: 2.5rem;
		}
	}

	.site-footer__name {
		margin: 0 0 0.9rem;
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--color-primary);
	}

	.site-footer__text {
		margin: 0 0 1.25rem;
		max-width: 28rem;
		color: var(--color-text-muted);
		line-height: 1.7;
		font-size: 1rem;
	}

	.site-footer__cta {
		min-height: 2.7rem;
		font-size: 0.9rem;
	}

	.site-footer__heading {
		margin: 0 0 1.1rem;
		font-family: var(--font-display);
		font-size: 0.86rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.site-footer__col {
		display: grid;
		align-content: start;
		gap: 0.9rem;
	}

	.site-footer__col a {
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.45;
		padding-block: 0.15rem;
		transition: color 0.2s var(--ease-out);
	}

	.site-footer__col a:hover,
	.site-footer__col a:focus-visible {
		color: var(--color-text);
	}

	.site-footer__bottom {
		width: min(100% - 1.5rem, var(--content-max-width));
		margin: 3rem auto 0;
		padding: 1.5rem 0 2rem;
		border-top: 1px solid var(--color-primary-line);
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.site-footer__copy {
		margin: 0;
	}

	.site-footer__nav-rows {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.site-footer__legal {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.15rem;
		line-height: 1.6;
	}

	.site-footer__legal-item {
		display: inline-flex;
		align-items: center;
		gap: 0.15rem;
	}

	.site-footer__legal a {
		color: var(--color-text-muted);
		padding: 0.2rem 0.35rem;
		border-radius: 0.25rem;
		transition: color 0.2s var(--ease-out);
	}

	.site-footer__legal a:hover,
	.site-footer__legal a:focus-visible {
		color: var(--color-primary);
		outline: none;
	}

	.site-footer__legal a:focus-visible {
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 55%, transparent);
	}

	.site-footer__sep {
		color: color-mix(in srgb, var(--color-text-muted) 70%, transparent);
		user-select: none;
		padding-inline: 0.15rem;
	}

	@media (min-width: 900px) {
		.site-footer__bottom {
			flex-direction: row;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1.5rem;
		}

		.site-footer__nav-rows {
			align-items: flex-end;
		}

		.site-footer__legal {
			justify-content: flex-end;
		}
	}
</style>
