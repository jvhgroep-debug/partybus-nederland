---
import type { GuideScenario } from '../../data/guides/pricingGuide';

interface Props {
	eyebrow?: string;
	title: string;
	lead?: string;
	items: readonly GuideScenario[];
}

const { eyebrow = 'Voorbeelden', title, lead, items } = Astro.props;
const titleId = `guide-scenarios-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 40)}`;
---

<section class="section guide-scenarios" aria-labelledby={titleId}>
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">{eyebrow}</p>
			<h2 id={titleId} class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
		</div>
		<div class="guide-scenarios__list">
			{
				items.map((item) => (
					<article class="guide-scenarios__item reveal">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.guide-scenarios__list {
		display: grid;
		gap: 1rem;
	}

	.guide-scenarios__item {
		padding: 1.3rem 1.25rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.guide-scenarios__item h3 {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		font-size: 1.08rem;
		color: var(--color-primary);
	}

	.guide-scenarios__item p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}
</style>
