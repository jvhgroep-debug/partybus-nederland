---
import type { GuideFaq } from '../../data/guides/pricingGuide';

interface Props {
	eyebrow?: string;
	title: string;
	lead?: string;
	items: readonly GuideFaq[];
}

const { eyebrow = 'Veelgestelde vragen', title, lead, items } = Astro.props;
---

<section id="faq" class="section guide-faq" aria-labelledby="guide-faq-title">
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">{eyebrow}</p>
			<h2 id="guide-faq-title" class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
		</div>
		<div class="guide-faq__list">
			{
				items.map((item) => (
					<details class="guide-faq__item reveal">
						<summary>{item.question}</summary>
						<div class="guide-faq__panel">
							<p>{item.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<style>
	.guide-faq__list {
		display: grid;
		gap: 0.65rem;
		max-width: 48rem;
	}

	.guide-faq__item {
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.guide-faq__item summary {
		cursor: pointer;
		list-style: none;
		padding: 1.05rem 1.2rem;
		font-weight: 700;
		font-family: var(--font-display);
		font-size: 1.02rem;
	}

	.guide-faq__item summary::-webkit-details-marker {
		display: none;
	}

	.guide-faq__panel {
		padding: 0 1.2rem 1.15rem;
	}

	.guide-faq__panel p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.7;
	}
</style>
