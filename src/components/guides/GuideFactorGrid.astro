---
import type { GuideFactor } from '../../data/guides/pricingGuide';

interface Props {
	eyebrow?: string;
	title: string;
	lead?: string;
	items: readonly GuideFactor[];
	columns?: 2 | 3;
}

const { eyebrow = 'Informatie', title, lead, items, columns = 3 } = Astro.props;
const titleId = `guide-factors-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 40)}`;
---

<section class="section guide-factors" aria-labelledby={titleId} data-columns={columns}>
	<div class="section__inner">
		<div class="section__head reveal">
			<p class="section__eyebrow">{eyebrow}</p>
			<h2 id={titleId} class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
		</div>
		<div class="guide-factors__grid">
			{
				items.map((item) => (
					<article class="guide-factors__card reveal">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.guide-factors__grid {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 700px) {
		.guide-factors__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.guide-factors[data-columns='3'] .guide-factors__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.guide-factors__card {
		padding: 1.25rem 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
		height: 100%;
	}

	.guide-factors__card h3 {
		margin: 0 0 0.5rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		color: var(--color-primary);
	}

	.guide-factors__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
		font-size: 0.95rem;
	}
</style>
