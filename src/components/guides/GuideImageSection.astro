---
import GuideImage from './GuideImage.astro';
import type { GuideImageAsset } from '../../data/guides/guideImages';

interface Props {
	image: GuideImageAsset;
	/** Image column on desktop — alternates per section for visual rhythm. */
	imagePosition?: 'left' | 'right';
	eyebrow?: string;
	title: string;
	titleId: string;
	lead?: string;
	paragraphs?: readonly string[];
	class?: string;
}

const {
	image,
	imagePosition = 'left',
	eyebrow,
	title,
	titleId,
	lead,
	paragraphs = [],
	class: className,
} = Astro.props;
---

<section
	class:list={['guide-image-section', 'section', `guide-image-section--${imagePosition}`, className]}
	aria-labelledby={titleId}
>
	<div class="section__inner guide-image-section__inner reveal">
		<div class="guide-image-section__media">
			<GuideImage image={image} variant="inline" sizes="(min-width: 960px) 44vw, 100vw" />
		</div>
		<div class="guide-image-section__content">
			{eyebrow && <p class="section__eyebrow">{eyebrow}</p>}
			<h2 id={titleId} class="section__title">{title}</h2>
			{lead && <p class="section__lead">{lead}</p>}
			<div class="guide-image-section__body">
				{paragraphs.map((paragraph) => <p>{paragraph}</p>)}
				<slot />
			</div>
		</div>
	</div>
</section>

<style>
	.guide-image-section__inner {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.75rem);
		align-items: center;
	}

	.guide-image-section__body :global(p:last-child) {
		margin-bottom: 0;
	}

	.guide-image-section__body p {
		margin: 0 0 1rem;
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.guide-image-section__body :global(a) {
		color: var(--color-primary);
		font-weight: 600;
	}

	.guide-image-section__body :global(ul) {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.65rem;
	}

	.guide-image-section__body :global(li) {
		position: relative;
		padding-left: 1.35rem;
		color: var(--color-text-muted);
		line-height: 1.55;
	}

	.guide-image-section__body :global(li::before) {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55rem;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-primary);
	}

	@media (min-width: 960px) {
		.guide-image-section__inner {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
			gap: clamp(2rem, 4vw, 3.5rem);
		}

		.guide-image-section--right .guide-image-section__media {
			order: 2;
		}

		.guide-image-section--right .guide-image-section__content {
			order: 1;
		}
	}
</style>
