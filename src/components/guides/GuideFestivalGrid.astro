---
import type { GuideFestival } from '../../data/guides/festivalGuide';

interface Props {
	items: readonly GuideFestival[];
}

const { items } = Astro.props;
---

<div class="guide-festivals section__inner">
	<div class="guide-festivals__grid">
			{
				items.map((item) => (
					<article class="guide-festivals__card reveal" id={item.slug}>
						<header class="guide-festivals__head">
							<h3>{item.name}</h3>
							<p class="guide-festivals__location">{item.location}</p>
						</header>
						<p class="guide-festivals__desc">{item.description}</p>
						<div class="guide-festivals__why">
							<p class="guide-festivals__why-label">Waarom een partybus?</p>
							<p>{item.partybusWhy}</p>
						</div>
						{
							item.href && (
								<p class="guide-festivals__link">
									<a href={item.href}>{item.linkLabel ?? `Meer over ${item.name}`}</a>
								</p>
							)
						}
					</article>
				))
			}
		</div>
</div>

<style>
	.guide-festivals__grid {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 700px) {
		.guide-festivals__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.guide-festivals__card {
		padding: 1.35rem 1.25rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
		height: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.guide-festivals__head h3 {
		margin: 0 0 0.25rem;
		font-family: var(--font-display);
		font-size: 1.15rem;
		color: var(--color-primary);
	}

	.guide-festivals__location {
		margin: 0;
		font-size: 0.88rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: color-mix(in srgb, var(--color-text) 70%, transparent);
	}

	.guide-festivals__desc,
	.guide-festivals__why p:last-child {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
		font-size: 0.95rem;
	}

	.guide-festivals__why {
		margin-top: auto;
		padding-top: 0.85rem;
		border-top: 1px solid var(--color-primary-line);
	}

	.guide-festivals__why-label {
		margin: 0 0 0.35rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.guide-festivals__link {
		margin: 0;
	}

	.guide-festivals__link a {
		color: var(--color-primary);
		font-weight: 600;
		font-size: 0.95rem;
	}
</style>
