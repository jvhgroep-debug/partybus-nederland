---
import Button from '../buttons/Button.astro';

interface Props {
	eyebrow?: string;
	title: string;
	lead: string;
	primaryHref?: string;
	primaryLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
	/** Full-bleed background (e.g. homepage hero). Omit for text-only guide heroes. */
	image?: string;
	imageWidth?: number;
	imageHeight?: number;
	imageAlt?: string;
}

const {
	eyebrow = 'GIDS',
	title,
	lead,
	primaryHref = '/gratis-partybus-offertes-aanvragen/',
	primaryLabel = 'Gratis offertes aanvragen',
	secondaryHref,
	secondaryLabel,
	image,
	imageWidth = 1536,
	imageHeight = 1024,
	imageAlt = '',
} = Astro.props;

const hasMedia = Boolean(image);
---

<header class:list={['guide-hero', hasMedia && 'guide-hero--media']}>
	{
		hasMedia && (
			<div class="guide-hero__media" aria-hidden="true">
				<img
					src={image}
					alt={imageAlt}
					width={imageWidth}
					height={imageHeight}
					fetchpriority="high"
					decoding="async"
				/>
				<div class="guide-hero__veil"></div>
			</div>
		)
	}

	<div class:list={[hasMedia ? 'guide-hero__content section__inner' : 'guide-hero__content section__inner guide-hero__content--plain']}>
		<p class="section__eyebrow">{eyebrow}</p>
		<h1 class="guide-hero__title">{title}</h1>
		<p class="guide-hero__lead">{lead}</p>
		{
			(primaryHref || secondaryHref) && (
				<div class="guide-hero__actions">
					{primaryHref && (
						<Button href={primaryHref} size="lg">
							{primaryLabel}
						</Button>
					)}
					{secondaryHref && secondaryLabel && (
						<a class="btn btn--ghost btn--lg" href={secondaryHref}>
							{secondaryLabel}
						</a>
					)}
				</div>
			)
		}
	</div>
</header>

<style>
	.guide-hero {
		position: relative;
	}

	.guide-hero--media {
		isolation: isolate;
		min-height: min(70vh, 38rem);
		min-height: min(70dvh, 38rem);
		display: grid;
		align-items: end;
		overflow: hidden;
		background: #000;
	}

	.guide-hero__media {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.guide-hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 45%;
		transform: scale(1.04);
	}

	.guide-hero__veil {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at center, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.72) 72%),
			linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.42) 40%, rgba(0, 0, 0, 0.84) 100%);
	}

	.guide-hero__content--plain {
		padding-top: calc(var(--header-height) + 2rem);
		padding-bottom: 2rem;
	}

	.guide-hero--media .guide-hero__content {
		padding-top: calc(var(--header-height) + 2.5rem);
		padding-bottom: clamp(2.5rem, 6vw, 4rem);
		width: 100%;
	}

	.guide-hero__title {
		margin: 0 0 1rem;
		max-width: 16ch;
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 800;
		line-height: 1.06;
		letter-spacing: -0.03em;
	}

	.guide-hero__lead {
		margin: 0 0 1.5rem;
		max-width: 42rem;
		font-size: 1.08rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-text) 88%, transparent);
	}

	.guide-hero--media .guide-hero__lead {
		color: color-mix(in srgb, var(--color-text) 92%, transparent);
		text-shadow: 0 1px 18px rgba(0, 0, 0, 0.45);
	}

	.guide-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	@media (max-width: 640px) {
		.guide-hero__actions :global(.btn) {
			width: 100%;
			justify-content: center;
		}

		.guide-hero--media {
			min-height: min(78vh, 34rem);
			min-height: min(78dvh, 34rem);
		}
	}
</style>
