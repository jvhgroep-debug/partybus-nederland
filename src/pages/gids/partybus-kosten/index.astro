---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideBreadcrumbs from '../../../components/guides/GuideBreadcrumbs.astro';
import GuideHero from '../../../components/guides/GuideHero.astro';
import GuideFactorGrid from '../../../components/guides/GuideFactorGrid.astro';
import GuideChecklist from '../../../components/guides/GuideChecklist.astro';
import GuideScenarioList from '../../../components/guides/GuideScenarioList.astro';
import GuideFaqList from '../../../components/guides/GuideFaqList.astro';
import GuideRelatedLinks from '../../../components/guides/GuideRelatedLinks.astro';
import GuideCta from '../../../components/guides/GuideCta.astro';
import GuideImageSection from '../../../components/guides/GuideImageSection.astro';
import {
	pricingBreadcrumbs,
	pricingFactorsDetailed,
	pricingFaqs,
	pricingGuideSeo,
	pricingInternalLinks,
	pricingScenarios,
	quoteChecklist,
	savingsTips,
} from '../../../data/guides/pricingGuide';
import { guideImagePool } from '../../../data/guides/guideImages';
import { pricingRequestFields, pricingVisualSections } from '../../../data/guides/guideVisualSections';
import {
	buildBreadcrumbSchema,
	buildFaqPageSchema,
	buildWebPageSchema,
} from '../../../lib/guides/schema';

const seo = pricingGuideSeo;
const img = guideImagePool;
const [intro, onderweg, interieur, opstap, aankomst, terugreis] = pricingVisualSections;

const jsonLd = [
	buildWebPageSchema({
		name: seo.h1,
		description: seo.description,
		url: seo.canonical,
	}),
	buildBreadcrumbSchema(pricingBreadcrumbs),
	buildFaqPageSchema(pricingFaqs),
];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonical={seo.canonical}
	titleExact={true}
	preloadImage="/images/hero-partybus.png"
	ogTitle={seo.title}
	ogDescription={seo.description}
	ogUrl={seo.canonical}
	ogImage={seo.ogImage}
	twitterTitle={seo.title}
	twitterDescription={seo.description}
	twitterImage={seo.ogImage}
	jsonLd={jsonLd}
>
	<article class="pricing-guide">
		<GuideBreadcrumbs items={pricingBreadcrumbs} />

		<GuideHero
			eyebrow={seo.eyebrow}
			title={seo.h1}
			lead={seo.lead}
			image="/images/hero-partybus.png"
			imageAlt="Luxe zwarte partybus met paarse LED-verlichting — partybus huren in Nederland"
			primaryHref="/gratis-partybus-offertes-aanvragen/"
			primaryLabel="Gratis offertes aanvragen"
			secondaryHref="/gids/partybus-huren/"
			secondaryLabel="Algemene partybus-gids"
		/>

		<GuideImageSection {...intro} />

		<GuideFactorGrid
			eyebrow="Prijsfactoren"
			title="Belangrijkste factoren die de prijs bepalen"
			lead="Geen vaste landelijke tarieven — wel duidelijke bouwstenen waarmee je offertes begrijpt en vergelijkt."
			items={pricingFactorsDetailed}
			columns={3}
		/>

		<GuideImageSection {...onderweg}>
			<ul class="pricing-guide__needs">
				{pricingRequestFields.map((item) => <li>{item}</li>)}
			</ul>
		</GuideImageSection>

		<GuideScenarioList
			eyebrow="Voorbeeldsituaties"
			title="Zo ziet een rit eruit — zonder bedragen"
			lead="Deze scenario’s helpen je plannen. Ze geven geen prijsindicatie in euro’s, wel een beeld van wat je in de aanvraag zet."
			items={pricingScenarios}
		/>

		<GuideImageSection {...interieur} />

		<GuideFactorGrid
			eyebrow="Bespaartips"
			title="Praktische tips om scherper te vergelijken"
			lead="Je hoeft niet op kwaliteit in te leveren. Wel kun je met een goede voorbereiding relevantere en vergelijkbaardere offertes krijgen."
			items={savingsTips}
			columns={3}
		/>

		<GuideImageSection {...opstap} />

		<GuideChecklist
			eyebrow="Checklist"
			title="Checklist voor een goede offerteaanvraag"
			lead="Hoe completer je aanvraag, hoe bruikbaarder de prijsvoorstellen."
			items={quoteChecklist}
		/>

		<GuideImageSection {...aankomst} />

		<GuideImageSection {...terugreis} />

		<GuideFaqList
			title="Veelgestelde vragen over partybus-prijzen"
			lead="Antwoorden op de vragen die we het vaakst horen over kosten en offertes."
			items={pricingFaqs}
		/>

		<GuideRelatedLinks
			title="Handige pagina’s om verder te gaan"
			lead="Van offerte tot steden, festivals en de algemene gids."
			items={pricingInternalLinks}
		/>
	</article>

	<GuideCta
		eyebrow="Prijzen"
		title="Klaar om offertes te vergelijken?"
		lead="Gebruik de checklist hierboven en vraag vrijblijvend meerdere prijsvoorstellen aan."
		titleId="pricing-cta"
		image={img.cta}
		showWhatsapp={false}
	/>
</BaseLayout>

<style>
	.pricing-guide :global(.section) {
		padding-block: clamp(3.5rem, 8vw, 6.5rem);
	}

	.pricing-guide__needs {
		margin: 0;
		padding: 1.15rem 1.2rem;
		list-style: none;
		display: grid;
		gap: 0.65rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: #0a0a0a;
	}
</style>
