---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/home/Hero.astro';
import GuideBreadcrumbs from '../../../components/guides/GuideBreadcrumbs.astro';
import GuideFactorGrid from '../../../components/guides/GuideFactorGrid.astro';
import GuideChecklist from '../../../components/guides/GuideChecklist.astro';
import GuideFaqList from '../../../components/guides/GuideFaqList.astro';
import GuideRelatedLinks from '../../../components/guides/GuideRelatedLinks.astro';
import GuideCta from '../../../components/guides/GuideCta.astro';
import GuideImageSection from '../../../components/guides/GuideImageSection.astro';
import {
	festivalBenefits,
	festivalBreadcrumbs,
	festivalChecklist,
	festivalCityLinks,
	festivalFaqs,
	festivalGuideLinks,
	festivalGuideSeo,
	festivalTips,
	festivalWhatsappHref,
	topFestivals,
} from '../../../data/guides/festivalGuide';
import { guideImagePool } from '../../../data/guides/guideImages';
import { festivalVisualSections } from '../../../data/guides/guideVisualSections';
import {
	buildBreadcrumbSchema,
	buildFaqPageSchema,
	buildWebPageSchema,
} from '../../../lib/guides/schema';

const seo = festivalGuideSeo;
const img = guideImagePool;
const [onderweg, opstap, festival, sfeer, aankomst, terugreis] = festivalVisualSections;

const jsonLd = [
	buildWebPageSchema({
		name: seo.h1,
		description: seo.description,
		url: seo.canonical,
	}),
	buildBreadcrumbSchema(festivalBreadcrumbs),
	buildFaqPageSchema(festivalFaqs),
];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonical={seo.canonical}
	titleExact={true}
	preloadImage="/images/hero-partybus.png"
	ogTitle={seo.title}
	ogDescription={seo.description}
	ogUrl={seo.canonical}
	ogImage={seo.ogImage}
	twitterTitle={seo.title}
	twitterDescription={seo.description}
	twitterImage={seo.ogImage}
	jsonLd={jsonLd}
>
	<article class="festival-guide">
		<Hero
			brand={seo.eyebrow}
			title={seo.h1}
			subtitle={seo.lead}
			image="/images/hero-partybus.png"
			imageLoading="eager"
			showScroll={false}
			titleId="festival-hero-title"
			primaryHref="/gratis-partybus-offertes-aanvragen/"
			primaryLabel="Gratis offertes aanvragen"
			secondaryHref="/gids/partybus-kosten/"
			secondaryLabel="Bekijk de prijzengids"
		/>

		<div class="festival-guide__crumbs">
			<GuideBreadcrumbs items={festivalBreadcrumbs} />
		</div>

		<GuideImageSection {...onderweg} />

		<GuideFactorGrid
			eyebrow="Voordelen"
			title="Voordelen van festivalvervoer per partybus"
			lead="Praktisch, veilig en sfeervol — zo blijft de groep bij elkaar van deur tot festivalterrein."
			items={festivalBenefits}
			columns={3}
		/>

		<GuideImageSection {...opstap} />

		<GuideFactorGrid
			eyebrow="Topfestivals"
			title="Populaire festivals voor partybusritten"
			lead="Informatieve blokken per festival. Exacte data en edities wisselen per jaar — vermeld altijd het juiste evenement in je aanvraag."
			items={topFestivals}
			columns={2}
		/>

		<GuideImageSection {...festival} />

		<GuideFactorGrid
			eyebrow="Tips"
			title="Praktische tips voor festivalvervoer"
			lead="Met een goede voorbereiding voorkom je stress rond vertrek, bagage en terugreis."
			items={festivalTips}
			columns={3}
		/>

		<GuideImageSection {...sfeer} />

		<GuideChecklist
			eyebrow="Checklist"
			title="Checklist voor je festivalaanvraag"
			lead="Deze gegevens helpen aanbieders een passende rit voor te stellen."
			items={festivalChecklist}
		/>

		<GuideImageSection {...aankomst} />

		<GuideFaqList
			title="Veelgestelde vragen over festivalvervoer"
			lead="Antwoorden op de vragen die we het vaakst horen over prijzen, ophalen, terugreis en meer."
			items={festivalFaqs}
		/>

		<GuideImageSection {...terugreis} />

		<GuideRelatedLinks
			eyebrow="Steden"
			title="Partybus huren vanuit populaire steden"
			lead="Festivalvervoer vanuit jouw vertrekstad — met lokale tips en offertes."
			items={festivalCityLinks}
		/>

		<GuideRelatedLinks
			eyebrow="Meer lezen"
			title="Gerelateerde gidsen en gelegenheden"
			lead="Prijzen, algemene informatie en tips per gelegenheid."
			items={festivalGuideLinks}
		/>
	</article>

	<GuideCta
		eyebrow="Festivalvervoer"
		title={seo.ctaTitle}
		lead={seo.ctaLead}
		whatsappHref={festivalWhatsappHref}
		whatsappLabel="WhatsApp direct"
		titleId="festival-cta"
		image={img.cta}
	/>
</BaseLayout>

<style>
	.festival-guide :global(.section) {
		padding-block: clamp(3.5rem, 8vw, 6.5rem);
	}

	.festival-guide__crumbs {
		margin-top: 0.5rem;
	}
</style>
