---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/buttons/Button.astro';
import GuideBreadcrumbs from '../../../components/guides/GuideBreadcrumbs.astro';
import GuideFactorGrid from '../../../components/guides/GuideFactorGrid.astro';
import GuideChecklist from '../../../components/guides/GuideChecklist.astro';
import GuideFaqList from '../../../components/guides/GuideFaqList.astro';
import GuideRelatedLinks from '../../../components/guides/GuideRelatedLinks.astro';
import {
	festivalBenefits,
	festivalBreadcrumbs,
	festivalChecklist,
	festivalFaqs,
	festivalGuideSeo,
	festivalInternalLinks,
	festivalTips,
	festivalWhy,
	topFestivals,
} from '../../../data/guides/festivalGuide';
import {
	buildBreadcrumbSchema,
	buildFaqPageSchema,
	buildWebPageSchema,
} from '../../../lib/guides/schema';

const seo = festivalGuideSeo;

/** Same public asset as homepage Hero.astro */
const HERO_IMAGE = '/images/hero-partybus.png';

const jsonLd = [
	buildWebPageSchema({
		name: seo.h1,
		description: seo.description,
		url: seo.canonical,
	}),
	buildBreadcrumbSchema(festivalBreadcrumbs),
	buildFaqPageSchema(festivalFaqs),
];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonical={seo.canonical}
	titleExact={true}
	preloadImage={HERO_IMAGE}
	ogTitle={seo.title}
	ogDescription={seo.description}
	ogUrl={seo.canonical}
	ogImage={seo.ogImage}
	twitterTitle={seo.title}
	twitterDescription={seo.description}
	twitterImage={seo.ogImage}
	jsonLd={jsonLd}
>
	<article class="festival-guide">
		{/* Same <img> hero pattern as homepage — hardcoded path, positive z-index layers */}
		<section class="festival-hero" aria-labelledby="festival-hero-title">
			<div class="festival-hero__media" aria-hidden="true">
				<img
					src="/images/hero-partybus.png"
					alt=""
					width="1536"
					height="1024"
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
			</div>
			<div class="festival-hero__veil" aria-hidden="true"></div>
			<div class="festival-hero__content section__inner">
				<p class="section__eyebrow">{seo.eyebrow}</p>
				<h1 id="festival-hero-title" class="festival-hero__title">{seo.h1}</h1>
				<p class="festival-hero__lead">{seo.lead}</p>
				<div class="festival-hero__actions">
					<Button href="/gratis-partybus-offertes-aanvragen/" size="lg">
						Gratis offertes aanvragen
					</Button>
					<a class="btn btn--ghost btn--lg" href="/gids/partybus-kosten/">
						Bekijk de prijzengids
					</a>
				</div>
			</div>
		</section>

		<div class="festival-guide__crumbs">
			<GuideBreadcrumbs items={festivalBreadcrumbs} />
		</div>

		<section class="section" aria-labelledby="festival-why">
			<div class="section__inner">
				<div class="section__head reveal">
					<p class="section__eyebrow">Waarom partybus</p>
					<h2 id="festival-why" class="section__title">{festivalWhy.title}</h2>
					<p class="section__lead">{festivalWhy.lead}</p>
				</div>
				<div class="festival-guide__prose reveal">
					{festivalWhy.paragraphs.map((p) => <p>{p}</p>)}
				</div>
			</div>
		</section>

		<GuideFactorGrid
			eyebrow="Voordelen"
			title="Voordelen van festivalvervoer per partybus"
			lead="Praktisch, veilig en sfeervol — zo blijft de groep bij elkaar van deur tot festivalterrein."
			items={festivalBenefits}
			columns={3}
		/>

		<GuideFactorGrid
			eyebrow="Topfestivals"
			title="Populaire festivals voor partybusritten"
			lead="Informatieve blokken per festival. Exacte data en edities wisselen per jaar — vermeld altijd het juiste evenement in je aanvraag."
			items={topFestivals}
			columns={2}
		/>

		<GuideFactorGrid
			eyebrow="Tips"
			title="Praktische tips voor festivalvervoer"
			lead="Met een goede voorbereiding voorkom je stress rond vertrek, bagage en terugreis."
			items={festivalTips}
			columns={3}
		/>

		<GuideChecklist
			eyebrow="Checklist"
			title="Checklist voor je festivalaanvraag"
			lead="Deze gegevens helpen aanbieders een passende rit voor te stellen."
			items={festivalChecklist}
		/>

		<GuideFaqList
			title="Veelgestelde vragen over festivalvervoer"
			lead="Antwoorden op de vragen die we het vaakst horen rond festivals en partybussen."
			items={festivalFaqs}
		/>

		<GuideRelatedLinks
			title="Handige pagina’s om verder te gaan"
			lead="Steden, prijzen, de algemene gids en gelegenheden."
			items={festivalInternalLinks}
		/>

		<section class="section" aria-labelledby="festival-cta">
			<div class="section__inner festival-guide__cta reveal">
				<h2 id="festival-cta" class="section__title">Klaar voor jouw festivalrit?</h2>
				<p class="section__lead">
					Vraag vrijblijvend meerdere offertes aan voor heen- en terugrit vanuit jouw stad.
				</p>
				<Button href="/gratis-partybus-offertes-aanvragen/" size="lg">
					Gratis offertes aanvragen
				</Button>
			</div>
		</section>
	</article>
</BaseLayout>

<style>
	/* Layer order: image (0) → veil (1) → content (2). Never z-index: -1 (hides behind parent). */
	.festival-hero {
		position: relative;
		isolation: isolate;
		min-height: min(70vh, 38rem);
		min-height: min(70dvh, 38rem);
		display: grid;
		align-items: end;
		overflow: hidden;
		background: #000;
	}

	.festival-hero__media {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.festival-hero__media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		max-height: none;
		object-fit: cover;
		object-position: center 45%;
		transform: scale(1.04);
	}

	.festival-hero__veil {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background:
			radial-gradient(circle at center, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.72) 72%),
			linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.42) 40%, rgba(0, 0, 0, 0.84) 100%);
	}

	.festival-hero__content {
		position: relative;
		z-index: 2;
		padding-top: calc(var(--header-height) + 2.5rem);
		padding-bottom: clamp(2.5rem, 6vw, 4rem);
		width: 100%;
	}

	.festival-hero__title {
		margin: 0 0 1rem;
		max-width: 16ch;
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 800;
		line-height: 1.06;
		letter-spacing: -0.03em;
	}

	.festival-hero__lead {
		margin: 0 0 1.5rem;
		max-width: 42rem;
		font-size: 1.08rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-text) 92%, transparent);
		text-shadow: 0 1px 18px rgba(0, 0, 0, 0.45);
	}

	.festival-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	@media (max-width: 640px) {
		.festival-hero {
			min-height: min(78vh, 34rem);
			min-height: min(78dvh, 34rem);
		}

		.festival-hero__actions :global(.btn) {
			width: 100%;
			justify-content: center;
		}
	}

	.festival-guide :global(.section) {
		padding-block: clamp(3.5rem, 8vw, 6.5rem);
	}

	.festival-guide__crumbs {
		margin-top: 0.5rem;
	}

	.festival-guide__prose {
		max-width: 46rem;
	}

	.festival-guide__prose p {
		margin: 0 0 1rem;
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.festival-guide__cta {
		text-align: center;
	}
</style>
