---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/buttons/Button.astro';
import InfoGuide from '../../../components/shared/InfoGuide.astro';
import GuideImage from '../../../components/guides/GuideImage.astro';
import GuideCta from '../../../components/guides/GuideCta.astro';
import {
	bookingTips,
	compareChecklist,
	pricingFactors,
	occasionGuides,
} from '../../../data/guides/partybusInfo';
import { guideImagePool } from '../../../data/guides/guideImages';
import { homeFaqs } from '../../../data/settings/faq-home';

const title = 'Partybus huren: complete gids voor Nederland';
const description =
	'Alles over partybus huren in Nederland: prijzen zonder vaste tarieven, tips, bestemmingen, festivals, capaciteit tot 80 personen en waar je op let bij offertes.';
const canonical = 'https://www.partybusnederland.nl/gids/partybus-huren/';
const img = guideImagePool;

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: homeFaqs.slice(0, 5).map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};
---

<BaseLayout
	title={title}
	description={description}
	canonical={canonical}
	titleExact={true}
	ogTitle={title}
	ogDescription={description}
	ogUrl={canonical}
	ogImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	twitterTitle={title}
	twitterDescription={description}
	twitterImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	jsonLd={faqSchema}
>
	<article class="guide">
		<header class="guide__hero section__inner">
			<p class="section__eyebrow">Informatiegids</p>
			<h1 class="guide__title">Partybus huren in Nederland: de complete gids</h1>
			<p class="guide__lead">
				Partybus Nederland helpt je niet alleen offertes vergelijken. Op deze pagina vind je
				praktische informatie over prijzen, planning, bestemmingen, festivals en veelgestelde
				vragen — zodat je een weloverwogen keuze maakt.
			</p>
			<div class="guide__actions">
				<Button href="/gratis-partybus-offertes-aanvragen/" size="lg">Gratis offertes aanvragen</Button>
				<a class="btn btn--ghost btn--lg" href="/#steden">Bekijk steden</a>
			</div>
		</header>

		<div class="guide-visual section__inner">
			<GuideImage image={img.luxeExterieur} class="reveal" />
		</div>

		<section class="section" aria-labelledby="guide-what">
			<div class="section__inner guide__prose reveal">
				<h2 id="guide-what">Wat is een partybus precies?</h2>
				<p>
					Een partybus is een luxe groepsvoertuig met sfeerverlichting, muziek en ruimte om samen te
					reizen. Je gebruikt hem als rijdend startpunt van je avond: iedereen blijft bij elkaar,
					zonder losse taxi’s of parkeerstress.
				</p>
				<p>
					Populaire toepassingen zijn vrijgezellenfeesten, bruiloften, bedrijfsuitjes, festivals,
					verjaardagen en stadsritten. Vanuit vrijwel elke stad in Nederland kun je een rit plannen
					naar een andere stad, een evenement of — in overleg — een bestemming in België.
				</p>
			</div>
		</section>

		<div class="guide-visual section__inner">
			<GuideImage image={img.groepInstapt} class="reveal" />
		</div>

		<InfoGuide
			eyebrow="Prijzen"
			title="Waar hangt de prijs van een partybus van af?"
			lead="Er bestaat geen vaste landelijke prijs. Gebruik deze factoren om offertes eerlijk te vergelijken — zonder verrassingen achteraf."
			cards={pricingFactors}
			checklist={compareChecklist}
		/>

		<div class="guide-visual section__inner">
			<GuideImage image={img.interieur} class="reveal" />
		</div>

		<InfoGuide
			eyebrow="Tips"
			title="Praktische tips voor een soepele rit"
			lead="Met een goede voorbereiding krijg je relevantere offertes en een rustiger feestavond."
			cards={bookingTips}
		/>

		<div class="guide-visual section__inner">
			<GuideImage image={img.onderweg} class="reveal" />
		</div>

		<section class="section" aria-labelledby="guide-occasions">
			<div class="section__inner">
				<div class="section__head reveal">
					<p class="section__eyebrow">Gelegenheden</p>
					<h2 id="guide-occasions" class="section__title">Per gelegenheid anders plannen</h2>
					<p class="section__lead">
						De beste partybusrit hangt af van jouw moment. Dit zijn de belangrijkste aandachtspunten.
					</p>
				</div>
				<div class="guide__cards">
					{
						occasionGuides.map((item) => (
							<article class="guide__card reveal">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<div class="guide-visual section__inner">
			<GuideImage image={img.festivalterrein} class="reveal" />
		</div>

		<section class="section" aria-labelledby="guide-destinations">
			<div class="section__inner guide__prose reveal">
				<h2 id="guide-destinations">Bestemmingen, festivals en routes</h2>
				<p>
					Veel groepen vertrekken vanuit hun eigen stad naar Amsterdam, Rotterdam, Utrecht, Den Haag,
					Eindhoven, festivals zoals Tomorrowland of Defqon.1, of naar Schiphol. Op onze
					stedenpagina’s vind je lokale context; op routepagina’s staat focus op een specifieke rit.
				</p>
				<p>
					<a href="/steden/partybus-huren-rotterdam/">Partybus vanuit Rotterdam</a>
					{' · '}
					<a href="/steden/partybus-huren-amsterdam/">Partybus vanuit Amsterdam</a>
					{' · '}
					<a href="/partybus-rotterdam-amsterdam/">Route Rotterdam – Amsterdam</a>
					{' · '}
					<a href="/partybus-rotterdam-tomorrowland/">Route Rotterdam – Tomorrowland</a>
				</p>
			</div>
		</section>

		<div class="guide-visual section__inner">
			<GuideImage image={img.festivalAankomst} class="reveal" />
		</div>

		<section class="section" aria-labelledby="guide-faq">
			<div class="section__inner guide__prose reveal">
				<h2 id="guide-faq">Kort antwoord op veelgestelde vragen</h2>
				<p>
					<strong>Hoeveel personen?</strong> Tot maximaal 80, afhankelijk van het voertuig.
				</p>
				<p>
					<strong>Kunnen we naar België?</strong> Vaak mogelijk voor festivals of steden — vermeld de
					bestemming in je aanvraag.
				</p>
				<p>
					<strong>Meerdere stops?</strong> Vaak mogelijk als je ze vooraf doorgeeft aan de aanbieder.
				</p>
				<p>
					<strong>Muziek en licht?</strong> Bij de meeste bussen onderdeel van de beleving; check
					exacte opties in de offerte.
				</p>
			</div>
		</section>

		<div class="guide-visual section__inner">
			<GuideImage image={img.terugreis} class="reveal" />
		</div>
	</article>

	<GuideCta
		eyebrow="Partybus huren"
		title="Klaar om te vergelijken?"
		lead="Gebruik de informatie hierboven, vraag daarna vrijblijvend meerdere offertes aan en kies zelf de beste optie."
		titleId="guide-cta"
		image={img.cta}
		showWhatsapp={false}
	/>
</BaseLayout>

<style>
	.guide__hero {
		padding-top: calc(var(--header-height) + 2rem);
		padding-bottom: 2rem;
	}

	.guide__title {
		margin: 0 0 1rem;
		max-width: 18ch;
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 800;
		line-height: 1.06;
		letter-spacing: -0.03em;
	}

	.guide__lead {
		margin: 0 0 1.5rem;
		max-width: 42rem;
		font-size: 1.08rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-text) 88%, transparent);
	}

	.guide__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.guide__prose {
		max-width: 46rem;
	}

	.guide__prose h2 {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: clamp(1.45rem, 3vw, 1.9rem);
	}

	.guide__prose p {
		margin: 0 0 1rem;
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.guide__prose a {
		color: var(--color-primary);
		font-weight: 600;
	}

	.guide__cards {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 700px) {
		.guide__cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.guide__card {
		padding: 1.25rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.guide__card h3 {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		color: var(--color-primary);
	}

	.guide__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	.guide-visual {
		padding-block: clamp(1rem, 3vw, 2rem);
	}

	@media (max-width: 640px) {
		.guide__actions :global(.btn) {
			width: 100%;
			justify-content: center;
		}
	}
</style>
