---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InfoGuide from '../../../components/shared/InfoGuide.astro';
import GuideHero from '../../../components/guides/GuideHero.astro';
import GuideImageSection from '../../../components/guides/GuideImageSection.astro';
import GuideCta from '../../../components/guides/GuideCta.astro';
import {
	bookingTips,
	compareChecklist,
	pricingFactors,
	occasionGuides,
} from '../../../data/guides/partybusInfo';
import { guideImagePool } from '../../../data/guides/guideImages';
import { partybusHurenVisualSections } from '../../../data/guides/guideVisualSections';
import { homeFaqs } from '../../../data/settings/faq-home';

const title = 'Partybus huren: complete gids voor Nederland';
const description =
	'Alles over partybus huren in Nederland: prijzen zonder vaste tarieven, tips, bestemmingen, festivals, capaciteit tot 80 personen en waar je op let bij offertes.';
const canonical = 'https://www.partybusnederland.nl/gids/partybus-huren/';
const img = guideImagePool;
const [onderweg, opstap, sfeer, festival, aankomst, terugreis] = partybusHurenVisualSections;

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: homeFaqs.slice(0, 5).map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};
---

<BaseLayout
	title={title}
	description={description}
	canonical={canonical}
	titleExact={true}
	preloadImage="/images/hero-partybus.png"
	ogTitle={title}
	ogDescription={description}
	ogUrl={canonical}
	ogImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	twitterTitle={title}
	twitterDescription={description}
	twitterImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	jsonLd={faqSchema}
>
	<article class="guide">
		<GuideHero
			eyebrow="Informatiegids"
			title="Partybus huren in Nederland: de complete gids"
			lead="Partybus Nederland helpt je niet alleen offertes vergelijken. Op deze pagina vind je praktische informatie over prijzen, planning, bestemmingen, festivals en veelgestelde vragen — zodat je een weloverwogen keuze maakt."
			image="/images/hero-partybus.png"
			imageAlt="Luxe zwarte partybus met paarse LED-verlichting — complete gids partybus huren Nederland"
			primaryHref="/gratis-partybus-offertes-aanvragen/"
			primaryLabel="Gratis offertes aanvragen"
			secondaryHref="/#steden"
			secondaryLabel="Bekijk steden"
		/>

		<GuideImageSection {...onderweg} />

		<GuideImageSection {...opstap} />

		<InfoGuide
			eyebrow="Prijzen"
			title="Waar hangt de prijs van een partybus van af?"
			lead="Er bestaat geen vaste landelijke prijs. Gebruik deze factoren om offertes eerlijk te vergelijken — zonder verrassingen achteraf."
			cards={pricingFactors}
			checklist={compareChecklist}
			hideHead={true}
		/>

		<GuideImageSection {...sfeer} />

		<InfoGuide
			eyebrow="Tips"
			title="Praktische tips voor een soepele rit"
			lead="Met een goede voorbereiding krijg je relevantere offertes en een rustiger feestavond."
			cards={bookingTips}
			hideHead={true}
		/>

		<GuideImageSection {...festival} />

		<section class="section" aria-labelledby="guide-occasions-cards">
			<div class="section__inner">
				<div class="guide__cards">
					{
						occasionGuides.map((item) => (
							<article class="guide__card reveal">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<GuideImageSection {...aankomst}>
			<p>
				<a href="/steden/partybus-huren-rotterdam/">Partybus vanuit Rotterdam</a>
				{' · '}
				<a href="/steden/partybus-huren-amsterdam/">Partybus vanuit Amsterdam</a>
				{' · '}
				<a href="/partybus-rotterdam-amsterdam/">Route Rotterdam – Amsterdam</a>
				{' · '}
				<a href="/partybus-rotterdam-tomorrowland/">Route Rotterdam – Tomorrowland</a>
			</p>
		</GuideImageSection>

		<GuideImageSection {...terugreis} />
	</article>

	<GuideCta
		eyebrow="Partybus huren"
		title="Klaar om te vergelijken?"
		lead="Gebruik de informatie hierboven, vraag daarna vrijblijvend meerdere offertes aan en kies zelf de beste optie."
		titleId="guide-cta"
		image={img.cta}
		showWhatsapp={false}
	/>
</BaseLayout>

<style>
	.guide :global(.section) {
		padding-block: clamp(3.5rem, 8vw, 6.5rem);
	}

	.guide__cards {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 700px) {
		.guide__cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.guide__card {
		padding: 1.25rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.guide__card h3 {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		color: var(--color-primary);
	}

	.guide__card p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}
</style>
