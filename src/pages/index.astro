---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import TrustBar from '../components/home/TrustBar.astro';
import Intro from '../components/home/Intro.astro';
import Services from '../components/home/Services.astro';
import PopularCities from '../components/home/PopularCities.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import OccasionsGuide from '../components/home/OccasionsGuide.astro';
import InfoGuide from '../components/shared/InfoGuide.astro';
import Reviews from '../components/home/Reviews.astro';
import FAQPreview from '../components/home/FAQPreview.astro';
import KnowledgeHub from '../components/home/KnowledgeHub.astro';
import CTA from '../components/home/CTA.astro';
import SafetyAndPartners from '../components/home/SafetyAndPartners.astro';
import { bookingTips, compareChecklist, pricingFactors } from '../data/guides/partybusInfo';
import { homeFaqs } from '../data/settings/faq-home';

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: homeFaqs.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'Partybus Nederland',
	url: 'https://www.partybusnederland.nl/',
	description: 'Vergelijkingsplatform voor partybusverhuur in Nederland.',
	contactPoint: {
		'@type': 'ContactPoint',
		contactType: 'customer service',
		availableLanguage: ['nl'],
	},
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Partybus Nederland',
	url: 'https://www.partybusnederland.nl/',
	inLanguage: 'nl-NL',
};
---

<BaseLayout
	title="Partybus huren in Nederland | Informatie, tips & offertes vergelijken"
	description="Complete informatie over partybus huren in Nederland: prijzen, tips, bestemmingen, festivals en routes. Vergelijk daarna gratis meerdere offertes."
	titleExact={true}
	jsonLd={[organizationSchema, websiteSchema, faqSchema]}
>
	<Hero
		title="Vergelijk partybussen. Kies de beste rit voor jouw groep."
		subtitle="Eén gratis aanvraag, meerdere passende offertes. Vergelijk luxe, capaciteit, voorwaarden en prijs — jij kiest zelf."
		secondaryHref="#werkwijze"
		secondaryLabel="Zo werkt vergelijken"
	/>
	<TrustBar />
	<Intro />
	<HowItWorks />
	<Services />
	<SafetyAndPartners />
	<Reviews />
	<InfoGuide
		eyebrow="Prijzen & planning"
		title="Waar hangt de prijs van een partybus van af?"
		lead="Geen vaste landelijke tarieven. Wel heldere factoren waarmee je offertes eerlijk naast elkaar legt."
		cards={pricingFactors}
		checklist={compareChecklist}
	/>
	<PopularCities />
	<OccasionsGuide />
	<KnowledgeHub />
	<InfoGuide
		eyebrow="Tips"
		title="Tips voor een geslaagde partybusrit"
		lead="Praktische aandachtspunten vóór je boekt — handig voor festivals, stedenritten en groepsfeesten."
		cards={bookingTips}
	/>
	<FAQPreview />
	<CTA />
</BaseLayout>
