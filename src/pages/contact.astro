---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/settings/site';
import { whatsapp } from '../data/settings/whatsapp';
import { emailSettings } from '../data/settings/email';
import { primaryCta } from '../data/settings/navigation';
import Button from '../components/buttons/Button.astro';
---

<BaseLayout title="Contact">
	<section class="section contact">
		<div class="section__inner contact__inner">
			<div class="contact__copy reveal">
				<p class="section__eyebrow">Contact</p>
				<h1 class="section__title">Neem contact op met {site.name}</h1>
				<p class="section__lead">
					Heb je een vraag over partybus huren of wil je direct offertes aanvragen?
					Bereik ons snel via WhatsApp — zonder formulier, zonder wachttijd.
				</p>
				<div class="contact__actions">
					<Button href={whatsapp.href} size="lg" target="_blank" rel="noopener noreferrer">
						WhatsApp: {whatsapp.phoneDisplay}
					</Button>
					<Button href={primaryCta.href} variant="ghost" size="lg">{primaryCta.label}</Button>
				</div>
			</div>

			<div class="contact__card reveal">
				<h2>Direct geregeld</h2>
				<ul>
					<li>WhatsApp: {whatsapp.phoneDisplay}</li>
					<li>
						E-mail:{' '}
						<a href={`mailto:${emailSettings.inbox}`}>{emailSettings.inbox}</a>
					</li>
					<li>Reactie meestal binnen 24 uur</li>
					<li>Door heel Nederland</li>
					<li>Vrijblijvend offertes vergelijken</li>
				</ul>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.contact {
		padding-top: calc(var(--header-height) + 2.5rem);
	}

	.contact__inner {
		display: grid;
		gap: 2rem;
	}

	@media (min-width: 900px) {
		.contact__inner {
			grid-template-columns: 1.2fr 0.8fr;
			gap: 3rem;
			align-items: start;
		}
	}

	.contact .section__title {
		max-width: 14ch;
	}

	.contact__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.75rem;
	}

	.contact__card {
		padding: 1.6rem 1.45rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 7%, #0a0a0a);
		box-shadow: var(--shadow-card);
	}

	.contact__card h2 {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: 1.2rem;
		color: var(--color-primary);
	}

	.contact__card ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.85rem;
		color: var(--color-text-muted);
	}

	.contact__card li {
		position: relative;
		padding-left: 1.2rem;
	}

	.contact__card li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6rem;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-primary);
	}

	@media (max-width: 640px) {
		.contact__actions :global(.btn) {
			width: 100%;
		}
	}
</style>