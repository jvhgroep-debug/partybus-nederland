---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/settings/site';
import { whatsapp } from '../data/settings/whatsapp';
import { emailSettings } from '../data/settings/email';
import Button from '../components/buttons/Button.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';
---

<BaseLayout title="Contact">
	<section class="section contact">
		<div class="section__inner contact__inner">
			<div class="contact__copy reveal">
				<p class="section__eyebrow">Contact</p>
				<h1 class="section__title">Neem contact op met {site.name}</h1>
				<p class="section__lead">
					Vraag vrijblijvend offertes aan via het formulier, of bereik ons direct via WhatsApp.
				</p>
				<div class="contact__actions">
					<Button href={whatsapp.href} size="lg" target="_blank" rel="noopener noreferrer">
						WhatsApp: {whatsapp.phoneDisplay}
					</Button>
					<Button href="#offerte" variant="ghost" size="lg">Naar het formulier</Button>
				</div>

				<div class="contact__card">
					<h2>Direct geregeld</h2>
					<ul>
						<li>WhatsApp: {whatsapp.phoneDisplay}</li>
						<li>
							E-mail:{' '}
							<a href={`mailto:${emailSettings.inbox}`}>{emailSettings.inbox}</a>
						</li>
						<li>Reactie meestal binnen 24 uur</li>
						<li>Door heel Nederland</li>
						<li>Vrijblijvend offertes vergelijken</li>
					</ul>
				</div>
			</div>

			<div id="offerte" class="contact__form reveal">
				<p class="section__eyebrow">Offerteaanvraag</p>
				<h2 class="section__title">Gratis offertes aanvragen</h2>
				<p class="section__lead">
					Vul het formulier in. Je ontvangt een bevestiging per e-mail.
				</p>
				<QuoteForm sourcePage="/contact/" />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.contact {
		padding-top: calc(var(--header-height) + 2.5rem);
	}

	.contact__inner {
		display: grid;
		gap: 2.5rem;
	}

	@media (min-width: 960px) {
		.contact__inner {
			grid-template-columns: 0.95fr 1.05fr;
			gap: 3rem;
			align-items: start;
		}
	}

	.contact .section__title {
		max-width: 14ch;
	}

	.contact__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.75rem;
	}

	.contact__card {
		margin-top: 2rem;
		padding: 1.6rem 1.45rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 7%, #0a0a0a);
		box-shadow: var(--shadow-card);
	}

	.contact__card h2 {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: 1.2rem;
		color: var(--color-primary);
	}

	.contact__card ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.85rem;
		color: var(--color-text-muted);
	}

	.contact__card li {
		position: relative;
		padding-left: 1.2rem;
	}

	.contact__card li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6rem;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-primary);
	}

	.contact__form {
		padding: 1.6rem 1.4rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.contact__form .section__title {
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		max-width: 16ch;
	}

	.contact__form .section__lead {
		margin-bottom: 1.35rem;
	}

	@media (max-width: 640px) {
		.contact__actions :global(.btn) {
			width: 100%;
		}
	}
</style>
