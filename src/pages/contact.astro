---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideBreadcrumbs from '../components/guides/GuideBreadcrumbs.astro';
import { site } from '../data/settings/site';
import { whatsapp } from '../data/settings/whatsapp';
import { emailSettings } from '../data/settings/email';
import Button from '../components/buttons/Button.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';
import { buildContactPageSchema, buildOrganizationSchema } from '../data/trust/pages';
import { buildBreadcrumbSchema } from '../lib/guides/schema';

const title = 'Contact | Partybus Nederland';
const description =
	'Neem contact op met Partybus Nederland via e-mail, WhatsApp of het offerteformulier. Vrijblijvend offertes vergelijken.';
const canonical = 'https://www.partybusnederland.nl/contact/';

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Contact' },
] as const;

const jsonLd = [
	buildContactPageSchema({
		name: 'Contact',
		description,
		url: canonical,
	}),
	buildOrganizationSchema(),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout
	title={title}
	description={description}
	canonical={canonical}
	titleExact={true}
	ogTitle={title}
	ogDescription={description}
	ogUrl={canonical}
	ogImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	twitterTitle={title}
	twitterDescription={description}
	twitterImage="https://www.partybusnederland.nl/images/hero-partybus.png"
	jsonLd={jsonLd}
>
	<article class="contact">
		<GuideBreadcrumbs items={breadcrumbs} />

		<section class="section contact__section">
			<div class="section__inner contact__inner">
				<div class="contact__copy reveal">
					<p class="section__eyebrow">Contact</p>
					<h1 class="section__title">Neem contact op met {site.name}</h1>
					<p class="section__lead">
						Stel je vraag via e-mail of WhatsApp, of vraag vrijblijvend offertes aan via het
						formulier. We reageren zo snel mogelijk — zonder harde reactietijdgarantie.
					</p>
					<div class="contact__actions">
						<Button href={whatsapp.href} size="lg" target="_blank" rel="noopener noreferrer">
							WhatsApp: {whatsapp.phoneDisplay}
						</Button>
						<Button href="/gratis-partybus-offertes-aanvragen/" variant="ghost" size="lg">
							Naar het offerteformulier
						</Button>
					</div>

					<div class="contact__card">
						<h2>Contactgegevens</h2>
						<ul>
							<li>
								E-mail:{' '}
								<a href={`mailto:${emailSettings.inbox}`}>{emailSettings.inbox}</a>
							</li>
							<li>
								WhatsApp:{' '}
								<a href={whatsapp.href} target="_blank" rel="noopener noreferrer">
									{whatsapp.phoneDisplay}
								</a>
							</li>
							<li>We streven ernaar zo snel mogelijk te reageren</li>
							<li>Aanvragen zijn vrijblijvend</li>
							<li>Door heel Nederland</li>
						</ul>
					</div>

					<nav class="contact__legal" aria-label="Juridische pagina’s">
						<a href="/privacybeleid/">Privacybeleid</a>
						<span aria-hidden="true">·</span>
						<a href="/algemene-voorwaarden/">Voorwaarden</a>
						<span aria-hidden="true">·</span>
						<a href="/disclaimer/">Disclaimer</a>
					</nav>
				</div>

				<div id="offerte" class="contact__form reveal">
					<p class="section__eyebrow">Offerteaanvraag</p>
					<h2 class="contact__form-title">Gratis offertes aanvragen</h2>
					<p class="section__lead">
						Vul het formulier in. Je ontvangt een bevestiging per e-mail. Prijzen en beschikbaarheid
						verschillen per aanbieder.
					</p>
					<QuoteForm sourcePage="/contact/" />
				</div>
			</div>
		</section>
	</article>
</BaseLayout>

<style>
	.contact__section {
		padding-top: 1rem;
	}

	.contact__inner {
		display: grid;
		gap: 2.5rem;
	}

	@media (min-width: 960px) {
		.contact__inner {
			grid-template-columns: 0.95fr 1.05fr;
			gap: 3rem;
			align-items: start;
		}
	}

	.contact .section__title {
		max-width: 14ch;
	}

	.contact__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.75rem;
	}

	.contact__card {
		margin-top: 2rem;
		padding: 1.6rem 1.45rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 7%, #0a0a0a);
		box-shadow: var(--shadow-card);
	}

	.contact__card h2 {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: 1.2rem;
		color: var(--color-primary);
	}

	.contact__card ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.85rem;
		color: var(--color-text-muted);
	}

	.contact__card li {
		position: relative;
		padding-left: 1.2rem;
	}

	.contact__card li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6rem;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-primary);
	}

	.contact__card a {
		color: var(--color-primary);
		font-weight: 600;
	}

	.contact__legal {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.5rem;
		margin-top: 1.5rem;
		font-size: 0.95rem;
	}

	.contact__legal a {
		color: var(--color-text-muted);
		font-weight: 600;
	}

	.contact__legal a:hover,
	.contact__legal a:focus-visible {
		color: var(--color-primary);
	}

	.contact__form {
		padding: 1.6rem 1.4rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-primary-line);
		background: color-mix(in srgb, var(--color-primary) 5%, #090909);
	}

	.contact__form-title {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		max-width: 16ch;
	}

	.contact__form .section__lead {
		margin-bottom: 1.35rem;
	}

	@media (max-width: 640px) {
		.contact__actions :global(.btn) {
			width: 100%;
		}
	}
</style>
