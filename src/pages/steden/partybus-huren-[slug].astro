---
import CityLayout from '../../layouts/CityLayout.astro';
import MasterCityTemplate from '../../components/cities/MasterCityTemplate.astro';
import { resolveCityHeroImage } from '../../lib/cityImages';
import { ALL_CITY_SLUGS, buildCityPageData } from '../../data/cities/pilotFactory';

export function getStaticPaths() {
	/** Static city folders keep their own index.astro to preserve existing routes. */
	const STATIC_CITY_SLUGS = new Set(['amsterdam', 'rotterdam', 'breda']);
	return ALL_CITY_SLUGS.filter((slug) => !STATIC_CITY_SLUGS.has(slug)).map((slug) => ({
		params: { slug },
	}));
}

const { slug } = Astro.params;
if (!slug) {
	throw new Error('Missing city slug');
}

const city = buildCityPageData(slug);
if (!city) {
	throw new Error(`Unknown city: ${slug}`);
}

const heroImage = resolveCityHeroImage(city.slug);

const webPageLd = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: city.metaTitle,
	description: city.metaDescription,
	url: city.canonical,
	inLanguage: 'nl-NL',
	isPartOf: {
		'@type': 'WebSite',
		name: 'Partybus Nederland',
		url: 'https://www.partybusnederland.nl/',
	},
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.partybusnederland.nl/' },
		{ '@type': 'ListItem', position: 2, name: 'Steden', item: 'https://www.partybusnederland.nl/#steden' },
		{ '@type': 'ListItem', position: 3, name: city.h1, item: city.canonical },
	],
};

const faqLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: city.faqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: { '@type': 'Answer', text: faq.answer },
	})),
};

const ogImage = `https://www.partybusnederland.nl${heroImage.src}`;
---

<CityLayout
	title={city.metaTitle}
	description={city.metaDescription}
	canonical={city.canonical}
	preloadImage={heroImage.src}
	ogTitle={city.metaTitle}
	ogDescription={city.metaDescription}
	ogUrl={city.canonical}
	ogImage={ogImage}
	twitterTitle={city.metaTitle}
	twitterDescription={city.metaDescription}
	twitterImage={ogImage}
	jsonLd={[webPageLd, breadcrumbLd, faqLd]}
>
	<MasterCityTemplate city={city} />
</CityLayout>
