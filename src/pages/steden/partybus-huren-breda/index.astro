---
import CityLayout from '../../../layouts/CityLayout.astro';
import MasterCityTemplate from '../../../components/cities/MasterCityTemplate.astro';
import { bredaCity as city } from '../../../data/cities/breda';
import { resolveCityHeroImage } from '../../../lib/cityImages';

const heroImage = resolveCityHeroImage(city.slug);

const webPageLd = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: city.metaTitle,
	description: city.metaDescription,
	url: city.canonical,
	inLanguage: 'nl-NL',
	isPartOf: {
		'@type': 'WebSite',
		name: 'Partybus Nederland',
		url: 'https://www.partybusnederland.nl/',
	},
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: 'https://www.partybusnederland.nl/',
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Steden',
			item: 'https://www.partybusnederland.nl/#steden',
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: city.h1,
			item: city.canonical,
		},
	],
};

const faqLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: city.faqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer,
		},
	})),
};

const ogImage = `https://www.partybusnederland.nl${heroImage.src}`;
---

<CityLayout
	title={city.metaTitle}
	description={city.metaDescription}
	canonical={city.canonical}
	preloadImage={heroImage.src}
	ogTitle={city.metaTitle}
	ogDescription={city.metaDescription}
	ogUrl={city.canonical}
	ogImage={ogImage}
	twitterTitle={city.metaTitle}
	twitterDescription={city.metaDescription}
	twitterImage={ogImage}
	jsonLd={[webPageLd, breadcrumbLd, faqLd]}
>
	<MasterCityTemplate city={city} />
</CityLayout>
