---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publishedCities } from '../../data/cities/registry';
import { routePages } from '../../data/routes/routes';
import { hubGuideLinks, legacyGuideLinks } from '../../data/gidsen/shared';
import { gidsenPath } from '../../data/gidsen/registry';
import { legalNav } from '../../data/legal/pages';

const title = 'HTML-sitemap | Partybus Nederland';
const description =
	'Overzicht van alle pagina’s op Partybus Nederland: kennisbank, gidsen, steden, routes en contact.';
const canonical = 'https://www.partybusnederland.nl/sitemap/';

const mainPages = [
	{ label: 'Home', href: '/' },
	{ label: 'Kennisbank', href: '/gidsen/' },
	{ label: 'Gratis offertes aanvragen', href: '/gratis-partybus-offertes-aanvragen/' },
	{ label: 'HTML-sitemap', href: '/sitemap/' },
];
---

<BaseLayout title={title} description={description} canonical={canonical} titleExact={true}>
	<div class="html-sitemap section__inner">
		<h1>HTML-sitemap</h1>
		<p>Overzicht van alle pagina’s in deze website-build. Alleen bestaande, bereikbare URL’s.</p>

		<section>
			<h2>Hoofdpagina’s</h2>
			<ul>
				{mainPages.map((item) => (
					<li>
						<a href={item.href}>{item.label}</a>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>Kennisbank (/gidsen/)</h2>
			<ul>
				<li>
					<a href="/gidsen/">Kennisbank-overzicht</a>
				</li>
				{hubGuideLinks.map((guide) => (
					<li>
						<a href={gidsenPath(guide.slug)}>{guide.label}</a>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>Originele gidsen (/gids/)</h2>
			<ul>
				{legacyGuideLinks.map((item) => (
					<li>
						<a href={item.href}>{item.label}</a>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>Steden</h2>
			<ul>
				{publishedCities.map((city) => (
					<li>
						<a href={city.path}>Partybus huren {city.name}</a>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>Routes</h2>
			<ul>
				{routePages.map((route) => (
					<li>
						<a href={route.path}>
							{route.departureCity} – {route.destination}
						</a>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>Contact & juridisch</h2>
			<ul>
				{legalNav.map((item) => (
					<li>
						<a href={item.href}>{item.label}</a>
					</li>
				))}
			</ul>
		</section>
	</div>
</BaseLayout>

<style>
	.html-sitemap {
		padding-top: calc(var(--header-height) + 2rem);
		padding-bottom: 4rem;
	}

	.html-sitemap h1 {
		margin: 0 0 0.5rem;
		font-family: var(--font-display);
	}

	.html-sitemap > p {
		margin: 0 0 2rem;
		color: var(--color-text-muted);
	}

	.html-sitemap section {
		margin-bottom: 2rem;
	}

	.html-sitemap h2 {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: 1.2rem;
		color: var(--color-primary);
	}

	.html-sitemap ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.5rem;
	}

	@media (min-width: 700px) {
		.html-sitemap ul {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.html-sitemap a {
		color: var(--color-text-muted);
	}

	.html-sitemap a:hover {
		color: var(--color-primary);
	}

	.html-sitemap__note {
		margin: 1rem 0 0;
		max-width: 40rem;
		font-size: 0.92rem;
		line-height: 1.6;
		color: var(--color-text-muted);
	}
</style>
